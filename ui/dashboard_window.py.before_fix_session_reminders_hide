class SportsBoxscorePrefetchWorker(QObject):
    finished = Signal(int)
    failed = Signal(str)

    def __init__(self, leagues):
        super().__init__()
        self.leagues = leagues or []

    def run(self):
        warmed = 0

        try:
            for league_data in self.leagues:
                league = str(
                    getattr(league_data, "league", "") or ""
                ).upper()

                for game in getattr(league_data, "games", []) or []:
                    if not bool(getattr(game, "is_clickable", False)):
                        continue

                    game_id = str(
                        getattr(game, "game_id", "") or ""
                    ).strip()

                    if not game_id:
                        continue

                    if league == "MLB":
                        fetch_mlb_boxscore(game_id)
                    elif league in {"NFL", "NBA"}:
                        fetch_espn_boxscore(league, game_id)
                    else:
                        continue

                    warmed += 1
                    print(f"Box-score preload ready: {league} {game_id}")

            self.finished.emit(warmed)

        except Exception as error:
            self.failed.emit(str(error))


