class MLBBoxScoreWorker(QObject):
    finished = Signal(object)
    failed = Signal(str)

    def __init__(self, game_id):
        super().__init__()
        self.game_id = game_id

    def run(self):
        try:
            self.finished.emit(fetch_mlb_boxscore(self.game_id))
        except Exception as error:
            self.failed.emit(str(error))


