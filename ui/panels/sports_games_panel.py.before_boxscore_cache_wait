    def apply_boxscore(self, payload):
        payload = payload or {}
        teams = payload.get("teams", {}) or {}
        away = teams.get("away", {}) or {}
        home = teams.get("home", {}) or {}

        if not away or not home:
            self.apply_error("MLB did not return both team box scores for this game.")
            return

        away_team = (away.get("team", {}) or {})
        home_team = (home.get("team", {}) or {})

        away_name = (
            away_team.get("name")
            or away_team.get("teamName")
            or "Away Team"
        )
        home_name = (
            home_team.get("name")
            or home_team.get("teamName")
            or "Home Team"
        )

        away_score = (
            ((away.get("teamStats", {}) or {}).get("batting", {}) or {})
            .get("runs", "")
        )
        home_score = (
            ((home.get("teamStats", {}) or {}).get("batting", {}) or {})
            .get("runs", "")
        )

        self.left_page.set_team(
            away_score,
            away_name,
            self.team_page_html(away),
        )
        self.right_page.set_team(
            home_score,
            home_name,
            self.team_page_html(home),
        )

        info = payload.get("info", []) or []
        status_text = self.fallback_title or "LIVE / FINAL MLB GAME"

        for entry in info:
            label = str(entry.get("label", "") or "").lower()
            value = str(entry.get("value", "") or "").strip()
            if label in {"game status", "status"} and value:
                status_text = value
                break

        self.status.setText(status_text.upper())

    @staticmethod
    def _mlb_player_sort_key(player):
        raw_order = str(player.get("battingOrder", "") or "")

        try:
            order_number = int(raw_order)
        except Exception:
            order_number = 999999

        return order_number

    @staticmethod
    def _mlb_batting_slot(player):
        raw_order = str(player.get("battingOrder", "") or "")

        try:
            order_number = int(raw_order)
        except Exception:
            return ""

        if order_number <= 0:
            return ""

        return str(order_number // 100)

    @staticmethod
    def _mlb_position_label(player):
        labels = []

        for position in player.get("allPositions", []) or []:
            label = str(position.get("abbreviation", "") or "").strip()
            if label and label not in labels:
                labels.append(label)

        if labels:
            return "-".join(labels)

        position = player.get("position", {}) or {}
        return str(position.get("abbreviation", "") or "").strip()

    @staticmethod
    def _mlb_is_substitute(player, seen_slot_count):
        game_status = player.get("gameStatus", {}) or {}

        if bool(game_status.get("isSubstitute")):
            return True

        return seen_slot_count > 0

    def _mlb_batting_players(self, team_data):
        players_by_id = team_data.get("players", {}) or {}
        ordered_players = []
        seen = set()

        for player_id in team_data.get("battingOrder", []) or []:
            key = f"ID{player_id}"
            player = players_by_id.get(key, {}) or {}

            if player and key not in seen:
                ordered_players.append(player)
                seen.add(key)

        # MLB includes substitution players in the players dict even when the
        # raw battingOrder list does not include every substituted row.
        extra_players = []
        for key, player in players_by_id.items():
            if key in seen:
                continue

            batting_stats = (player.get("stats", {}) or {}).get("batting", {}) or {}
            has_batting_order = bool(player.get("battingOrder"))

            if has_batting_order or batting_stats:
                extra_players.append(player)
                seen.add(key)

        extra_players.sort(key=self._mlb_player_sort_key)
        ordered_players.extend(extra_players)

        ordered_players.sort(key=self._mlb_player_sort_key)
        return ordered_players

    def team_page_html(self, team_data):
        team = team_data.get("team", {}) or {}
        team_name = str(team.get("name") or team.get("teamName") or "Team")
        abbreviation = str(team.get("abbreviation") or "")
        team_stats = team_data.get("teamStats", {}) or {}
        team_batting = team_stats.get("batting", {}) or {}
        team_pitching = team_stats.get("pitching", {}) or {}
        score = team_batting.get("runs", "")

        batting_rows = []
        slot_seen_counts = {}
        substitute_index = 0

        for player in self._mlb_batting_players(team_data):
            person = player.get("person", {}) or {}
            stats = (player.get("stats", {}) or {}).get("batting", {}) or {}
            season_stats = (
                (player.get("seasonStats", {}) or {}).get("batting", {}) or {}
            )

            name = escape(str(person.get("fullName") or "Player"))
            pos = escape(self._mlb_position_label(player))

            slot = self._mlb_batting_slot(player)
            seen_slot_count = slot_seen_counts.get(slot, 0)
            slot_seen_counts[slot] = seen_slot_count + 1

            prefix_html = ""
            if self._mlb_is_substitute(player, seen_slot_count):
                substitute_letter = chr(ord("a") + substitute_index)
                substitute_index += 1
                prefix_html = f"<span class='sub-prefix'>{substitute_letter} - </span>"

            batting_rows.append(
                "<tr>"
                f"<td class='name'>{prefix_html}{name} <span class='pos'>{pos}</span></td>"
                f"<td>{self._value(stats.get('atBats'))}</td>"
                f"<td>{self._value(stats.get('runs'))}</td>"
                f"<td>{self._value(stats.get('hits'))}</td>"
                f"<td>{self._value(stats.get('rbi'))}</td>"
                f"<td>{self._value(stats.get('homeRuns'))}</td>"
                f"<td>{self._value(stats.get('baseOnBalls'))}</td>"
                f"<td>{self._value(stats.get('strikeOuts'))}</td>"
                f"<td>{self._value(stats.get('avg') or season_stats.get('avg'))}</td>"
                f"<td>{self._value(stats.get('obp') or season_stats.get('obp'))}</td>"
                f"<td>{self._value(stats.get('slg') or season_stats.get('slg'))}</td>"
                "</tr>"
            )

        if not batting_rows:
            batting_rows.append("<tr><td colspan='11'>Batting statistics are not available yet.</td></tr>")

        batting_rows.append(
            "<tr class='team-total'>"
            "<td class='name'>TEAM</td>"
            f"<td>{self._value(team_batting.get('atBats'))}</td>"
            f"<td>{self._value(team_batting.get('runs'))}</td>"
            f"<td>{self._value(team_batting.get('hits'))}</td>"
            f"<td>{self._value(team_batting.get('rbi'))}</td>"
            f"<td>{self._value(team_batting.get('homeRuns'))}</td>"
            f"<td>{self._value(team_batting.get('baseOnBalls'))}</td>"
            f"<td>{self._value(team_batting.get('strikeOuts'))}</td>"
            "<td></td><td></td><td></td>"
            "</tr>"
        )

        pitching_rows = []
        for player_id in team_data.get("pitchers", []) or []:
            player = self._player(team_data, player_id)
            if not player:
                continue

            person = player.get("person", {}) or {}
            stats = (player.get("stats", {}) or {}).get("pitching", {}) or {}
            season_stats = (
                (player.get("seasonStats", {}) or {}).get("pitching", {}) or {}
            )
            name = escape(str(person.get("fullName") or "Pitcher"))

            pitches = stats.get("pitchesThrown")
            strikes = stats.get("strikes")
            pitch_strike = "—"
            if pitches not in (None, "") and strikes not in (None, ""):
                pitch_strike = f"{escape(str(pitches))}-{escape(str(strikes))}"

            pitching_rows.append(
                "<tr>"
                f"<td class='name'>{name}</td>"
                f"<td>{self._value(stats.get('inningsPitched'))}</td>"
                f"<td>{self._value(stats.get('hits'))}</td>"
                f"<td>{self._value(stats.get('runs'))}</td>"
                f"<td>{self._value(stats.get('earnedRuns'))}</td>"
                f"<td>{self._value(stats.get('baseOnBalls'))}</td>"
                f"<td>{self._value(stats.get('strikeOuts'))}</td>"
                f"<td>{self._value(stats.get('homeRuns'))}</td>"
                f"<td>{pitch_strike}</td>"
                f"<td>{self._value(stats.get('era') or season_stats.get('era'))}</td>"
                "</tr>"
            )

        if not pitching_rows:
            pitching_rows.append("<tr><td colspan='10'>Pitching statistics are not available yet.</td></tr>")

        total_pitches = team_pitching.get("pitchesThrown")
        total_strikes = team_pitching.get("strikes")
