class ESPNBoxScoreWorker(QObject):
    finished = Signal(object)
    failed = Signal(str)

    def __init__(self, league, game_id):
        super().__init__()
        self.league = str(league or "").upper()
        self.game_id = str(game_id or "")

    def run(self):
        try:
            self.finished.emit(fetch_espn_boxscore(self.league, self.game_id))
        except Exception as error:
            self.failed.emit(str(error))


