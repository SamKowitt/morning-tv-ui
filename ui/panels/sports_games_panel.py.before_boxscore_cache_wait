    @staticmethod
    def loading_html(title):
        return (
            "<div style='font-family:Georgia; font-size:26px; font-weight:bold;'>"
            f"{escape(title)}</div>"
            "<hr><div style='margin-top:28px; font-family:Georgia; font-size:18px;'>"
            "Loading box score...</div>"
        )

    @staticmethod
    def clean_value(value, fallback="—"):
        if value is None or value == "":
            return fallback
        return escape(str(value))

    def start_fetch(self):
        self.thread = QThread(self)
        self.worker = ESPNBoxScoreWorker(self.league, self.game_id)
        self.worker.moveToThread(self.thread)

        self.thread.started.connect(self.worker.run)
        self.worker.finished.connect(self.apply_boxscore)
        self.worker.failed.connect(self.apply_error)

        self.worker.finished.connect(self.thread.quit)
        self.worker.failed.connect(self.thread.quit)
        self.thread.finished.connect(self.worker.deleteLater)
        self.thread.finished.connect(self.thread.deleteLater)

        self.thread.start()

    def apply_error(self, message):
        safe_message = escape(str(message))
        html = (
            "<div style='font-family:Georgia; font-size:26px; font-weight:bold;'>"
            "Box score unavailable</div><hr>"
            f"<div style='margin-top:20px; font-family:Georgia; font-size:18px;'>{safe_message}</div>"
        )
        self.left_page.setHtml(html)
        self.right_page.setHtml(html)
        self.status.setText("Could not load box score")

    def team_side_map(self, payload):
        sides = {}

        competitions = (
            (payload.get("header", {}) or {})
            .get("competitions", [])
            or []
        )

        if not competitions:
            return sides

        for competitor in competitions[0].get("competitors", []) or []:
            team = competitor.get("team", {}) or {}
            team_id = str(team.get("id", "") or "")

            if team_id:
                sides[team_id] = competitor.get("homeAway", "")

        return sides

    def grouped_team_stats(self, payload):
        side_map = self.team_side_map(payload)
        groups = {"away": [], "home": []}

        for team_block in (
            (payload.get("boxscore", {}) or {})
            .get("players", [])
            or []
        ):
            team = team_block.get("team", {}) or {}
            team_id = str(team.get("id", "") or "")
            side = side_map.get(team_id)

            if side not in groups:
                continue

            groups[side].append(team_block)

        return groups

    def apply_boxscore(self, payload):
        payload = payload or {}
        grouped = self.grouped_team_stats(payload)

        if not grouped["away"] or not grouped["home"]:
            self.apply_error(
                f"ESPN did not return both team box scores for this {self.league} game."
            )
            return

        self.left_page.setHtml(self.team_page_html(grouped["away"]))
        self.right_page.setHtml(self.team_page_html(grouped["home"]))

        game_status = self.fallback_title or f"{self.league} LIVE / FINAL"
        competitions = (
            (payload.get("header", {}) or {})
            .get("competitions", [])
            or []
        )

        if competitions:
            status = competitions[0].get("status", {}) or {}
            detail = (
                status.get("type", {}) or {}
            ).get("detail") or status.get("displayClock")

            if detail:
                game_status = str(detail)

        self.status.setText(game_status.upper())

    def team_page_html(self, team_blocks):
        first_team = team_blocks[0].get("team", {}) or {}
        team_name = (
            first_team.get("displayName")
            or first_team.get("shortDisplayName")
            or first_team.get("name")
            or "Team"
        )

        sections = []

        for team_block in team_blocks:
            for stat_group in team_block.get("statistics", []) or []:
                group_name = (
                    stat_group.get("name")
                    or stat_group.get("displayName")
                    or "Statistics"
                )

                labels = (
                    stat_group.get("labels")
                    or stat_group.get("names")
                    or []
                )

                athletes = stat_group.get("athletes", []) or []

                if not athletes:
                    continue

                max_columns = min(len(labels), 8)
                headers = labels[:max_columns]

                rows = []
                for athlete_entry in athletes:
                    athlete = athlete_entry.get("athlete", {}) or {}
                    athlete_name = athlete.get("displayName") or athlete.get("shortName") or "Player"
                    position = (
                        athlete.get("position", {}) or {}
                    ).get("abbreviation", "")

                    values = athlete_entry.get("stats", []) or []
                    values = values[:max_columns]

                    cells = "".join(
                        f"<td>{self.clean_value(value)}</td>"
                        for value in values
                    )

                    rows.append(
                        "<tr>"
                        f"<td class='name'>{escape(str(athlete_name))} "
                        f"<span class='pos'>{escape(str(position))}</span></td>"
                        f"{cells}"
                        "</tr>"
                    )

                if not rows:
                    continue

                header_cells = "".join(
                    f"<th>{escape(str(label))}</th>"
                    for label in headers
                )

                sections.append(
                    "<h2>"
                    f"{escape(str(group_name)).upper()}"
                    "</h2>"
                    "<table>"
                    "<tr>"
                    "<th style='text-align:left'>PLAYER</th>"
                    f"{header_cells}"
                    "</tr>"
                    f"{''.join(rows)}"
                    "</table>"
                )

        if not sections:
            sections.append(
                "<div style='margin-top:24px; font-family:Georgia; font-size:18px;'>"
                "Detailed player statistics are not available yet."
                "</div>"
            )

        return f"""
        <html>
        <head>
        <style>
            body {{
                color: #1b130c;
                background: transparent;
                margin: 0;
                font-family: Arial, sans-serif;
            }}
            h1 {{
                font-family: Georgia, serif;
                font-size: 30px;
                margin: 0 0 6px 0;
            }}
            h2 {{
                font-family: Georgia, serif;
                font-size: 20px;
                margin: 16px 0 5px 0;
                border-bottom: 1px solid #80623c;
                padding-bottom: 3px;
            }}
            table {{
                border-collapse: collapse;
                width: 100%;
                font-size: 14px;
            }}
            th {{
                color: #3b2a18;
                text-align: center;
                border-bottom: 1px solid #80623c;
                padding: 4px 3px;
                font-weight: 700;
            }}
            td {{
                text-align: center;
                border-bottom: 1px solid #d2be95;
                padding: 5px 3px;
            }}
            td.name {{
                text-align: left;
                font-weight: 600;
                width: 34%;
            }}
            .pos {{
                color: #66523a;
                font-weight: normal;
            }}
        </style>
        </head>
        <body>
            <h1>{escape(str(team_name))} Box Score</h1>
            {''.join(sections)}
        </body>
        </html>
        """

    def closeEvent(self, event):
        if self.thread and self.thread.isRunning():
            self.thread.quit()
            self.thread.wait(500)

        super().closeEvent(event)


class SportsGamesPanel(QWidget):
    def __init__(self):
        super().__init__()

        self.setObjectName("NewspaperGamesCard")
        self.setAttribute(Qt.WA_StyledBackground, False)
        self.setMouseTracking(True)

        self.leagues = []
        self.clickable_rows = []
        self.boxscore_dialog = None
        self._last_leagues_signature = None
        self.edition_text = "Loading live schedules"
        self.message = "Checking MLB, NFL, and NBA schedules..."

        self.setMinimumHeight(120)

    def set_loading(self):
        self.edition_text = "LOADING LIVE SCHEDULES"
        self.leagues = []
        self.clickable_rows = []
        self.message = "Checking MLB, NFL, and NBA schedules..."
        self.unsetCursor()
        self.update()

    def set_error(self, message="Unable to load live games."):
        self.edition_text = "SCHEDULE UNAVAILABLE"
        self.leagues = []
        self.clickable_rows = []
        self.message = message
        self.unsetCursor()
        self.update()

    def normalize_game(self, game, league=""):
        if isinstance(game, dict):
            return {
                "matchup": game.get("matchup", ""),
                "time": game.get("time", ""),
                "detail": game.get("detail", ""),
                "league": game.get("league", league),
                "game_id": str(game.get("game_id", "") or ""),
                "is_clickable": bool(game.get("is_clickable", False)),
            }

        if isinstance(game, (tuple, list)):
            return {
                "matchup": game[0] if len(game) > 0 else "",
                "time": game[1] if len(game) > 1 else "",
                "detail": game[2] if len(game) > 2 else "",
                "league": league,
                "game_id": "",
                "is_clickable": False,
            }

        return {
            "matchup": getattr(game, "matchup", ""),
            "time": getattr(game, "time", ""),
            "detail": getattr(game, "detail", ""),
            "league": getattr(game, "league", league) or league,
            "game_id": str(getattr(game, "game_id", "") or ""),
            "is_clickable": bool(getattr(game, "is_clickable", False)),
        }

    def normalize_league(self, league_data):
        if isinstance(league_data, dict):
            emoji = league_data.get("emoji", "")
            league = league_data.get("league", "")
            games = league_data.get("games", [])
        else:
            emoji = getattr(league_data, "emoji", "")
            league = getattr(league_data, "league", "")
            games = getattr(league_data, "games", [])

        normalized_games = []
        for game in games:
            normalized = self.normalize_game(game, league=league)
            if normalized["matchup"] and normalized["time"]:
                normalized_games.append(normalized)

        return emoji, league, normalized_games

    def update_leagues(self, leagues):
        print("SportsGamesPanel received leagues:", leagues)

        active_leagues = []
        for league_data in leagues or []:
            emoji, league, games = self.normalize_league(league_data)
            print(f"Normalized league {league}: {len(games)} game(s)")

            if league:
                if not games:
                    games = [{
                        "matchup": "No games scheduled",
                        "time": "—",
                        "detail": "No games found today",
                        "league": league,
                        "game_id": "",
                        "is_clickable": False,
                    }]
                active_leagues.append((emoji, league, games[:3]))

        if not active_leagues:
            self.edition_text = "NO ACTIVE LEAGUES"
            self.leagues = []
            self.clickable_rows = []
            self.message = "No MLB, NFL, or NBA leagues are currently in season."
            self.unsetCursor()
            self.update()
            return

        signature = tuple(
            (
                emoji,
                league,
                tuple(
                    (
                        str(game.get("matchup", "") or ""),
                        str(game.get("time", "") or ""),
                        str(game.get("detail", "") or ""),
                        str(game.get("game_id", "") or ""),
                        bool(game.get("is_clickable", False)),
                    )
                    for game in games
                ),
            )
            for emoji, league, games in active_leagues
        )

        if signature == self._last_leagues_signature:
            print("Game Times unchanged. Keeping visible schedule.")
            return

        self._last_leagues_signature = signature
        league_names = " / ".join([league for _, league, _ in active_leagues])
        self.edition_text = f"IN SEASON: {league_names}"
        self.leagues = active_leagues
        self.message = ""
        self.update()

    def update_games_data(self, leagues):
        self.update_leagues(leagues)

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.Antialiasing)
        self.clickable_rows = []

        rect = self.rect().adjusted(1, 1, -1, -1)
        draw_stacked_newspaper_panel(painter, rect)

        inner = rect.adjusted(17, 9, -17, -13)
        self.draw_header(painter, inner)

        top_rule_y = inner.top() + 24
        bottom_rule_y = inner.bottom() - 15

        self.draw_rule(painter, inner.left(), top_rule_y, inner.right())
        self.draw_rule(painter, inner.left(), bottom_rule_y, inner.right())

        footer_font = QFont("Times New Roman", 7)
        footer_font.setBold(True)
        painter.setFont(footer_font)
        painter.setPen(QColor("#5a442b"))
        painter.drawText(
            QRectF(inner.left(), bottom_rule_y + 2, inner.width() / 2, 12),
            Qt.AlignLeft | Qt.AlignVCenter,
            "SCHEDULE BOARD",
        )
        painter.drawText(
            QRectF(inner.center().x(), bottom_rule_y + 2, inner.width() / 2, 12),
            Qt.AlignRight | Qt.AlignVCenter,
            "PAGE 2",
        )

        body = QRectF(
            inner.left(),
            top_rule_y + 2,
            inner.width(),
            bottom_rule_y - top_rule_y - 3,
        )

        if not self.leagues:
            self.draw_empty_state(painter, body)
            return

        self.draw_leagues(painter, body)

    def draw_header(self, painter, inner):
        title_font = QFont("Rockwell", 22)
        title_font.setBold(True)
        title_font.setLetterSpacing(QFont.PercentageSpacing, 106)
        painter.setFont(title_font)
        painter.setPen(QColor("#241a10"))
        painter.drawText(
            QRectF(inner.left(), inner.top() + 2, inner.width() * 0.72, 23),
            Qt.AlignLeft | Qt.AlignVCenter,
            "GAME TIMES",
        )

        edition_font = QFont("Georgia", 7)
        edition_font.setBold(True)
        edition_font.setLetterSpacing(QFont.PercentageSpacing, 108)
        painter.setFont(edition_font)
        painter.setPen(QColor("#5a442b"))
        painter.drawText(
            QRectF(
                inner.left() + inner.width() * 0.42,
                inner.top() + 2,
                inner.width() * 0.58,
                18,
            ),
            Qt.AlignRight | Qt.AlignVCenter,
            self.edition_text.upper(),
        )

    def draw_leagues(self, painter, body):
        column_count = max(1, len(self.leagues))
        column_width = body.width() / column_count

        for index, (emoji, league, games) in enumerate(self.leagues):
            left = body.left() + index * column_width
            col = QRectF(left, body.top(), column_width, body.height())

            if index > 0:
                painter.setPen(QPen(QColor(55, 42, 25, 125), 1))
                painter.drawLine(
                    int(col.left()), int(col.top()), int(col.left()), int(col.bottom())
                )

            padded = col.adjusted(7, 0, -7, 0)
            self.draw_league_column(painter, padded, emoji, league, games)

    def draw_league_column(self, painter, rect, emoji, league, games):
        heading_height = 23

        emoji_font = QFont("Arial", 15)
        painter.setFont(emoji_font)
        painter.setPen(QColor("#21170d"))
        painter.drawText(
            QRectF(rect.left(), rect.top(), 24, heading_height),
            Qt.AlignCenter,
            emoji,
        )

        league_font = QFont("Georgia", 17)
        league_font.setBold(True)
        painter.setFont(league_font)
        painter.setPen(QColor("#21170d"))
        painter.drawText(
            QRectF(rect.left() + 28, rect.top(), rect.width() - 28, heading_height),
            Qt.AlignLeft | Qt.AlignVCenter,
            league,
        )

        self.draw_rule(painter, rect.left(), rect.top() + heading_height, rect.right())

        rows_top = rect.top() + heading_height + 3
        rows_height = rect.height() - heading_height - 3
        row_count = max(2, len(games))
        row_height = rows_height / row_count

        for i in range(row_count):
            row = QRectF(
                rect.left(),
                rows_top + i * row_height,
                rect.width(),
                row_height,
            )

            if i < len(games):
                game = games[i]
                self.draw_game_row(
                    painter,
                    row,
                    game,
                    compact=len(games) >= 3,
                )
                if (
                    game.get("is_clickable")
                    and game.get("league") in {"MLB", "NFL", "NBA"}
                ):
                    self.clickable_rows.append((QRectF(row), game))

            if i < row_count - 1:
                self.draw_rule(painter, row.left(), row.bottom(), row.right())

    def draw_game_row(self, painter, row, game, compact=False):
        matchup = game.get("matchup", "")
        time = game.get("time", "")
        detail = game.get("detail", "")

        time_width = 58 if compact else 66
        time_font = QFont("Times New Roman", 10)
        time_font.setBold(True)
        painter.setFont(time_font)
        painter.setPen(QColor("#25190d"))
        painter.drawText(
            QRectF(row.left(), row.top() + 2, time_width, row.height() - 4),
            Qt.AlignLeft | Qt.AlignTop,
            time,
        )

        matchup_text = str(matchup or "").strip()
        detail_text = str(detail or "").strip()
        is_final_row = str(time or "").strip().upper() == "FINAL"
        is_multiline_score = "\n" in matchup_text or "\r" in matchup_text
        left = row.left() + time_width
        width = row.width() - time_width

        if is_final_row or is_multiline_score:
            score_lines = [
                line.strip()
                for line in matchup_text.replace("\r", "\n").split("\n")
                if line.strip()
            ]
            if not score_lines:
                score_lines = [matchup_text]

            score_font = QFont("Georgia", 12 if compact else 13)
            score_font.setBold(True)
            pitcher_font = QFont("Georgia", 12 if compact else 13)
            winner_font = QFont("Georgia", 12 if compact else 13)
            winner_font.setBold(True)

            score_top = row.top() + 1
            line_height = 16 if compact else 18

            for index, line in enumerate(score_lines[:2]):
                line_rect = QRectF(
                    left,
                    score_top + index * line_height,
                    width,
                    line_height + 2,
                )

                if " - " not in line:
                    painter.setFont(score_font)
                    painter.setPen(QColor("#17100a"))
                    painter.drawText(line_rect, Qt.AlignLeft | Qt.AlignVCenter, line)
                    continue

                bold_part, pitcher_part = line.split(" - ", 1)
                bold_text = f"{bold_part} - "
                painter.setFont(score_font)
                painter.setPen(QColor("#17100a"))
                painter.drawText(line_rect, Qt.AlignLeft | Qt.AlignVCenter, bold_text)

                bold_width = painter.fontMetrics().horizontalAdvance(bold_text)
                winner_suffix = ""
                pitcher_name = pitcher_part
                if pitcher_part.endswith(" (W)"):
                    pitcher_name = pitcher_part[:-4]
                    winner_suffix = " (W)"

                painter.setFont(pitcher_font)
                painter.setPen(QColor("#4f3c25"))
                painter.drawText(
                    QRectF(
                        left + bold_width,
                        line_rect.top(),
                        max(1, width - bold_width),
                        line_rect.height(),
                    ),
                    Qt.AlignLeft | Qt.AlignVCenter,
                    pitcher_name,
                )

                if winner_suffix:
                    pitcher_width = painter.fontMetrics().horizontalAdvance(pitcher_name)
                    painter.setFont(winner_font)
                    painter.setPen(QColor("#17100a"))
                    painter.drawText(
                        QRectF(
                            left + bold_width + pitcher_width,
                            line_rect.top(),
                            max(1, width - bold_width - pitcher_width),
                            line_rect.height(),
                        ),
                        Qt.AlignLeft | Qt.AlignVCenter,
                        winner_suffix,
                    )

            if detail_text:
                detail_font = QFont("Times New Roman", 13 if compact else 15)
                painter.setFont(detail_font)
                painter.setPen(QColor("#4f3c25"))
                detail_height = 18 if compact else 21
                painter.drawText(
                    QRectF(
                        left,
                        row.bottom() - detail_height - 5,
                        width,
                        detail_height,
                    ),
                    Qt.AlignLeft | Qt.AlignBottom,
                    detail_text,
                )
            return

        matchup_font = QFont("Georgia", 12 if compact else 14)
        matchup_font.setBold(True)
        painter.setFont(matchup_font)
        painter.setPen(QColor("#17100a"))
        painter.drawText(
            QRectF(left, row.top() + 1, width, row.height() * 0.42),
            Qt.AlignLeft | Qt.AlignVCenter,
            matchup_text,
        )

        if detail_text:
            detail_font = QFont("Times New Roman", 13 if compact else 15)
            painter.setFont(detail_font)
            painter.setPen(QColor("#4f3c25"))
            detail_height = 18 if compact else 21
            painter.drawText(
                QRectF(
                    left,
                    row.bottom() - detail_height - 5,
                    width,
                    detail_height,
                ),
                Qt.AlignLeft | Qt.AlignBottom,
                detail_text,
            )

    def mouseMoveEvent(self, event):
        point = event.position()
        is_clickable = any(row.contains(point) for row, _game in self.clickable_rows)
        self.setCursor(Qt.PointingHandCursor if is_clickable else Qt.ArrowCursor)
        super().mouseMoveEvent(event)

    def mousePressEvent(self, event):
        if event.button() == Qt.LeftButton:
            point = event.position()
            for row, game in self.clickable_rows:
                if row.contains(point):
                    self.open_boxscore(game)
                    event.accept()
                    return
        super().mousePressEvent(event)

    def _clear_boxscore_dialog_if_current(self, dialog):
        if self.boxscore_dialog is dialog:
            self.boxscore_dialog = None

    def open_boxscore(self, game):
        game_id = str(game.get("game_id", "") or "")
        league = str(game.get("league", "") or "").upper()

        if not game_id or league not in {"MLB", "NFL", "NBA"}:
            return

        if self.boxscore_dialog is not None:
            old_dialog = self.boxscore_dialog
            self.boxscore_dialog = None
            old_dialog.close()
            old_dialog.deleteLater()

        title = str(game.get("matchup", "") or "")
        dashboard_window = self.window()
        cached_payload = get_cached_boxscore(league, game_id)

        if cached_payload is not None:
            print(f"Game Times cache hit: {league} {game_id}")
        else:
            print(f"Game Times cache miss: {league} {game_id}")

        if league == "MLB":
            self.boxscore_dialog = MLBBoxScoreDialog(
                game_id,
                title,
                parent=dashboard_window,
                cached_payload=cached_payload,
            )
        else:
            self.boxscore_dialog = ESPNBoxScoreDialog(
                league,
                game_id,
                title,
                parent=dashboard_window,
                cached_payload=cached_payload,
            )

        dialog = self.boxscore_dialog
        dialog.destroyed.connect(
            lambda *_args, current_dialog=dialog:
            self._clear_boxscore_dialog_if_current(current_dialog)
        )

        parent_rect = dashboard_window.rect()

        # Match the fixed wide/tall newspaper proportion used by all article
        # popups instead of stretching box scores to a different shape.
        aspect_ratio = 1120 / 650
        max_width = int(parent_rect.width())
        max_height = int(parent_rect.height())

        width = max_width
        height = int(width / aspect_ratio)

        if height > max_height:
            height = max_height
            width = int(height * aspect_ratio)

        x = int((parent_rect.width() - width) / 2)
        y = int((parent_rect.height() - height) / 2)

        dialog.setGeometry(x, y, width, height)
        dialog.show()
        dialog.raise_()
        dialog.activateWindow()

