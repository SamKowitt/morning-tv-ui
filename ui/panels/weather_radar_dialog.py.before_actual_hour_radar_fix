from datetime import datetime, timedelta
from zoneinfo import ZoneInfo

from PySide6.QtCore import Qt, QThread, QTimer, Signal
from PySide6.QtGui import QColor, QFont, QLinearGradient, QPainter, QPainterPath, QPen, QPixmap
from PySide6.QtWidgets import (
    QDialog,
    QFrame,
    QHBoxLayout,
    QLabel,
    QPushButton,
    QVBoxLayout,
    QWidget,
)


class RadarPaperSurface(QWidget):
    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.Antialiasing, True)

        rect = self.rect().adjusted(1, 1, -1, -1)

        paper = QLinearGradient(rect.topLeft(), rect.bottomRight())
        paper.setColorAt(0.0, QColor("#fff1d3"))
        paper.setColorAt(0.48, QColor("#f6e4bd"))
        paper.setColorAt(0.52, QColor("#ead4a8"))
        paper.setColorAt(1.0, QColor("#fff0d0"))

        painter.setPen(QPen(QColor(75, 51, 28, 185), 1))
        painter.setBrush(paper)
        painter.drawRect(rect)

        center_x = rect.center().x()

        painter.setPen(QPen(QColor(91, 59, 31, 120), 1))
        painter.drawLine(center_x, rect.top() + 2, center_x, rect.bottom() - 2)


class RadarFetchWorker(QThread):
    ready = Signal(object)
    failed = Signal(str)

    def __init__(self, latitude, longitude, selected_start_utc):
        super().__init__()
        self.latitude = latitude
        self.longitude = longitude
        self.selected_start_utc = selected_start_utc

    def run(self):
        try:
            from services.weather_radar_fetcher import fetch_forecast_radar_frames

            frames = fetch_forecast_radar_frames(
                latitude=self.latitude,
                longitude=self.longitude,
                selected_start_utc=self.selected_start_utc,
            )
            self.ready.emit(frames)
        except Exception as error:
            self.failed.emit(str(error))


class WeatherRadarDialog(QDialog):
    def __init__(self, weather_row, row_index, location, parent=None):
        super().__init__(parent)

        self.weather_row = weather_row
        self.row_index = int(row_index)
        self.location = location
        self.frames = []
        self.frame_index = 0
        self.worker = None

        local_zone = ZoneInfo(getattr(location, "timezone", "America/New_York"))
        now_local = datetime.now(local_zone).replace(
            minute=0,
            second=0,
            microsecond=0,
        )
        self.selected_start_local = now_local + timedelta(hours=self.row_index)
        self.selected_start_utc = self.selected_start_local.astimezone(
            ZoneInfo("UTC")
        )

        self.setWindowTitle("Forecast Radar")
        self.setModal(False)
        self.setWindowFlags(Qt.Widget | Qt.FramelessWindowHint)
        self.setAttribute(Qt.WA_StyledBackground, True)
        self.resize(1120, 650)

        self.setStyleSheet("""
            QDialog {
                background-color: #2d2419;
            }

            QLabel#RadarMasthead {
                font-family: "Rockwell", "Georgia", serif;
                font-size: 27px;
                font-weight: 1000;
                color: #24170d;
                letter-spacing: 1.2px;
                background: transparent;
            }

            QLabel#RadarPageTitle {
                font-family: "Georgia";
                font-size: 19px;
                font-weight: 1000;
                color: #1b130c;
                background: transparent;
            }

            QLabel#RadarMeta,
            QLabel#RadarDetail {
                font-family: "American Typewriter", "Courier New", monospace;
                font-size: 15px;
                font-weight: 700;
                color: #1b130c;
                background: transparent;
            }

            QLabel#RadarImage {
                background: #d8e7ea;
                border: 1px solid rgba(70, 50, 28, 160);
            }

            QPushButton#RadarCloseButton {
                background-color: #f3e6c9;
                border: 2px solid rgba(70, 50, 28, 210);
                border-radius: 5px;
                color: #24170d;
                font-family: "Georgia";
                font-size: 18px;
                font-weight: 1000;
                padding: 7px 18px;
                min-width: 120px;
                min-height: 34px;
            }

            QPushButton#RadarCloseButton:hover {
                background-color: #fff0cf;
            }
        """)

        root = QVBoxLayout(self)
        root.setContentsMargins(18, 16, 18, 16)
        root.setSpacing(10)

        header = QHBoxLayout()
        self.masthead = QLabel("FORECAST RADAR")
        self.masthead.setObjectName("RadarMasthead")

        self.status_label = QLabel("Preparing NOAA HRRR forecast frames…")
        self.status_label.setStyleSheet("""
            QLabel {
                color: #e8d8b6;
                font-family: "Times New Roman";
                font-size: 13px;
                font-weight: 900;
                letter-spacing: 1px;
                background: transparent;
            }
        """)
        self.status_label.setAlignment(Qt.AlignRight | Qt.AlignVCenter)

        header.addWidget(self.masthead, 1)
        header.addWidget(self.status_label)
        root.addLayout(header)

        self.surface = RadarPaperSurface()
        surface_layout = QHBoxLayout(self.surface)
        surface_layout.setContentsMargins(20, 14, 20, 12)
        surface_layout.setSpacing(14)

        left_page = QWidget()
        left_layout = QVBoxLayout(left_page)
        left_layout.setContentsMargins(0, 0, 0, 0)
        left_layout.setSpacing(8)

        left_title = QLabel("LOCAL RADAR FORECAST")
        left_title.setObjectName("RadarPageTitle")

        self.radar_image = QLabel("Loading forecast reflectivity…")
        self.radar_image.setObjectName("RadarImage")
        self.radar_image.setAlignment(Qt.AlignCenter)
        self.radar_image.setMinimumSize(390, 380)

        self.radar_time_label = QLabel("")
        self.radar_time_label.setObjectName("RadarMeta")
        self.radar_time_label.setAlignment(Qt.AlignCenter)

        left_layout.addWidget(left_title)
        left_layout.addWidget(self.radar_image, 1)
        left_layout.addWidget(self.radar_time_label)

        right_page = QWidget()
        right_layout = QVBoxLayout(right_page)
        right_layout.setContentsMargins(10, 0, 0, 0)
        right_layout.setSpacing(12)

        right_title = QLabel("SELECTED HOUR")
        right_title.setObjectName("RadarPageTitle")

        selected_label = self.selected_start_local.strftime("%A, %-I:00 %p")
        location_label = getattr(location, "label", "") or "Saved location"

        details = [
            f"LOCATION\n{location_label}",
            f"TIME WINDOW\n{selected_label} to "
            f"{(self.selected_start_local + timedelta(hours=1)).strftime('%-I:00 %p')}",
            f"TEMPERATURE\n{getattr(weather_row, 'temperature', '--')}°",
            f"CONDITION\n{str(getattr(weather_row, 'condition', 'unknown')).upper()}",
            "RADAR TYPE\nHRRR MODEL FORECAST",
            "NOTE\nForecast reflectivity is predicted precipitation guidance, not observed live radar.",
        ]

        right_layout.addWidget(right_title)

        for detail in details:
            label = QLabel(detail)
            label.setObjectName("RadarDetail")
            label.setWordWrap(True)
            label.setAlignment(Qt.AlignLeft | Qt.AlignTop)
            right_layout.addWidget(label)

            rule = QFrame()
            rule.setFrameShape(QFrame.HLine)
            rule.setFixedHeight(1)
            rule.setStyleSheet(
                "background-color: rgba(90, 78, 63, 135); border: none;"
            )
            right_layout.addWidget(rule)

        right_layout.addStretch(1)

        surface_layout.addWidget(left_page, 1)
        surface_layout.addWidget(right_page, 1)
        root.addWidget(self.surface, 1)

        controls = QHBoxLayout()
        controls.addStretch(1)

        close_button = QPushButton("CLOSE")
        close_button.setObjectName("RadarCloseButton")
        close_button.clicked.connect(self.close)

        controls.addWidget(close_button)
        controls.addStretch(1)
        root.addLayout(controls)

        self.animation_timer = QTimer(self)
        self.animation_timer.setInterval(850)
        self.animation_timer.timeout.connect(self.advance_frame)

        self.start_fetch()

    def start_fetch(self):
        self.worker = RadarFetchWorker(
            latitude=self.location.latitude,
            longitude=self.location.longitude,
            selected_start_utc=self.selected_start_utc,
        )
        self.worker.ready.connect(self.apply_frames)
        self.worker.failed.connect(self.show_error)
        self.worker.finished.connect(self.worker.deleteLater)
        self.worker.start()

    def apply_frames(self, frames):
        self.frames = list(frames or [])
        self.frame_index = 0

        if not self.frames:
            self.show_error("NOAA did not return forecast radar frames.")
            return

        self.status_label.setText("HRRR forecast radar — 2 frame loop")
        self.show_frame()

        if len(self.frames) > 1:
            self.animation_timer.start()

    def show_frame(self):
        if not self.frames:
            return

        frame = self.frames[self.frame_index]
        pixmap = QPixmap()
        pixmap.loadFromData(frame["image_bytes"])

        if not pixmap.isNull():
            self.radar_image.setPixmap(
                pixmap.scaled(
                    self.radar_image.size(),
                    Qt.KeepAspectRatio,
                    Qt.SmoothTransformation,
                )
            )

        valid_time = frame["valid_time"].astimezone(
            ZoneInfo(getattr(self.location, "timezone", "America/New_York"))
        )
        self.radar_time_label.setText(
            valid_time.strftime("Forecast frame: %-I:%M %p")
        )

    def advance_frame(self):
        if len(self.frames) < 2:
            return

        self.frame_index = (self.frame_index + 1) % len(self.frames)
        self.show_frame()

    def resizeEvent(self, event):
        super().resizeEvent(event)
        self.show_frame()

    def show_error(self, message):
        self.animation_timer.stop()
        self.status_label.setText("Forecast radar unavailable")
        self.radar_image.setText(
            "Could not load NOAA HRRR forecast radar.\n\n"
            + str(message)
        )

    def closeEvent(self, event):
        self.animation_timer.stop()

        if self.worker and self.worker.isRunning():
            self.worker.quit()
            self.worker.wait(1500)

        super().closeEvent(event)
