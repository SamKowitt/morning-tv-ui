    def update_zoom_buttons(self):
        loading = bool(self.radar_fetch_in_progress)

        self.zoom_in_button.setEnabled(
            not loading and self.map_zoom < self.max_map_zoom
        )
        self.zoom_out_button.setEnabled(
            not loading and self.map_zoom > self.min_map_zoom
        )

    def start_fetch(self):
        try:
            if self.worker and self.worker.isRunning():
                return
        except RuntimeError:
            self.worker = None

        requested_zoom = self.map_zoom
        self.radar_fetch_in_progress = True
        self.update_zoom_buttons()

        try:
            from services.weather_radar_fetcher import (
                load_cached_weathercom_radar_frames,
            )

            cached_frames = load_cached_weathercom_radar_frames(
                latitude=self.location.latitude,
                longitude=self.location.longitude,
                selected_start_utc=self.selected_start_utc,
                selected_end_utc=self.selected_end_utc,
                zoom=requested_zoom,
            )

            if cached_frames:
                print(
                    "Opening radar directly from cache:",
                    f"zoom={requested_zoom},",
                    f"{len(cached_frames)} frame(s)",
                )
                self.apply_frames_for_zoom(
                    cached_frames,
                    requested_zoom,
                )
                self.radar_fetch_in_progress = False
                self.update_zoom_buttons()
                return

        except Exception as error:
            print(f"Radar cache lookup skipped: {error}")

        self.worker = RadarFetchWorker(
            latitude=self.location.latitude,
            longitude=self.location.longitude,
            selected_start_utc=self.selected_start_utc,
            selected_end_utc=self.selected_end_utc,
            location_label=self.location_label,
            map_zoom=requested_zoom,
        )

        self.worker.ready.connect(self.on_radar_fetch_ready)
        self.worker.failed.connect(self.on_radar_fetch_failed)
        self.worker.finished.connect(self.on_radar_fetch_finished)
        self.worker.start()

    def on_radar_fetch_ready(self, frames):
        self.apply_frames_for_zoom(frames, self.map_zoom)

    def on_radar_fetch_failed(self, message):
        self.show_error(message)

    def on_radar_fetch_finished(self):
        finished_worker = self.worker
        self.worker = None
        self.radar_fetch_in_progress = False
        self.update_zoom_buttons()

        if finished_worker is not None:
            finished_worker.deleteLater()


    def apply_frames_for_zoom(self, frames, zoom):
        if int(zoom) != self.map_zoom:
            return

        self.apply_frames(frames)

    def change_map_zoom(self, delta):
        if self.radar_fetch_in_progress:
            return

        new_zoom = max(
            self.min_map_zoom,
            min(
                self.max_map_zoom,
                self.map_zoom + int(delta),
            ),
        )

        if new_zoom == self.map_zoom:
            self.update_zoom_buttons()
            return

        self.map_zoom = new_zoom
        self.radar_view.set_message(
            f"Refreshing radar map at zoom {self.map_zoom}…"
        )

        self.start_fetch()

    def apply_frames(self, frames):
        incoming_frames = list(frames or [])
        self.frames = []
        self.pixmaps = []

        for frame in incoming_frames:
            pixmap = QPixmap()

            if pixmap.loadFromData(frame.get("image_bytes", b"")):
                self.frames.append(frame)
                self.pixmaps.append(pixmap)

        if len(self.pixmaps) < 4:
            self.show_error("Weather.com did not return enough radar images.")
            return

        self.frame_index = 0
        self.radar_timeline.set_frames(
            self.frames,
            self.local_zone,
        )

        legend_font_size = 18 if len(self.frames) <= 9 else 14
        self.radar_legend_label.setText(
            (
                f'<span style="font-family: American Typewriter; '
                f'font-size: {legend_font_size}px; color: #000000;">'
                f'● Observed</span><br>'
                f'<span style="font-family: American Typewriter; '
                f'font-size: {legend_font_size}px; color: #1F5DCC;">'
                f'● Predicted</span>'
            )
        )

        self.show_frame()

        radar_types = {
            str(frame.get("radar_type", "")).strip()
            for frame in self.frames
        }

        if len(radar_types) > 1:
            status_text = "Observed + predicted radar"
        else:
            status_text = next(
                iter(radar_types),
                "Weather.com radar",
            ).title()

        self.status_label.setText(
            f"{status_text} — cached locally for 5 minutes"
        )

        self.is_playing = True
        self.play_button.setText("PAUSE")
        self.animation_timer.start()

    def show_frame(self):
        if not self.pixmaps or not self.frames:
            return

        self.frame_index %= len(self.pixmaps)

        self.radar_view.set_frame(self.pixmaps[self.frame_index])
        self.radar_timeline.set_current_index(self.frame_index)

        # Timeline and legend show all radar timing and source details.
        # Keep the footer free of per-frame count, timestamp, provider,
        # and observed/predicted status text.

    def next_frame(self):
        if not self.pixmaps:
            return

        self.frame_index = (self.frame_index + 1) % len(self.pixmaps)
        self.show_frame()

    def previous_frame(self):
        if not self.pixmaps:
            return

        self.frame_index = (self.frame_index - 1) % len(self.pixmaps)
        self.show_frame()

    def toggle_playback(self):
        self.is_playing = not self.is_playing

        if self.is_playing:
            self.play_button.setText("PAUSE")
            self.animation_timer.start()
        else:
            self.play_button.setText("PLAY")
            self.animation_timer.stop()

    def show_error(self, message):
        self.animation_timer.stop()
        self.radar_legend_label.setText("")
        self.radar_view.set_message(message)
        self.radar_fetch_in_progress = False
        self.update_zoom_buttons()

    def closeEvent(self, event):
        self.animation_timer.stop()

        try:
            if self.worker and self.worker.isRunning():
                self.worker.wait(1500)
        except RuntimeError:
            pass

        super().closeEvent(event)
