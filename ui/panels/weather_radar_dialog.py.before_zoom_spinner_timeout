        self.default_map_zoom = 11
        self.map_zoom = self.default_map_zoom

        self.local_zone = ZoneInfo(
            getattr(location, "timezone", "America/New_York")
        )

        if selected_start_utc is not None:
            self.selected_start_utc = selected_start_utc.astimezone(
                ZoneInfo("UTC")
            )
            self.selected_end_utc = (
                selected_end_utc.astimezone(ZoneInfo("UTC"))
                if selected_end_utc is not None
                else self.selected_start_utc + timedelta(minutes=90)
            )
            self.selected_start_local = self.selected_start_utc.astimezone(
                self.local_zone
            )
            self.selected_end_local = self.selected_end_utc.astimezone(
                self.local_zone
            )
        else:
            forecast_start = str(
                getattr(weather_row, "forecast_start", "") or ""
            ).strip()

            try:
                parsed_start = datetime.fromisoformat(
                    forecast_start.replace("Z", "+00:00")
                )

                if parsed_start.tzinfo is None:
                    parsed_start = parsed_start.replace(
                        tzinfo=self.local_zone
