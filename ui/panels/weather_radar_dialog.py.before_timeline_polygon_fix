class RadarPaperSurface(QWidget):
    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.Antialiasing, True)

        rect = self.rect().adjusted(1, 1, -1, -1)

        paper = QLinearGradient(rect.topLeft(), rect.bottomRight())
        paper.setColorAt(0.0, QColor("#fff1d3"))
        paper.setColorAt(0.48, QColor("#f6e4bd"))
        paper.setColorAt(0.52, QColor("#ead4a8"))
        paper.setColorAt(1.0, QColor("#fff0d0"))

        painter.setPen(QPen(QColor(75, 51, 28, 185), 1))
        painter.setBrush(paper)
        painter.drawRect(rect)

        painter.setPen(QPen(QColor(91, 59, 31, 120), 1))
        painter.drawLine(
            rect.center().x(),
            rect.top() + 2,
            rect.center().x(),
            rect.bottom() - 2,
        )


class RadarLoopView(QWidget):
    def __init__(self):
        super().__init__()

        self.pixmap = QPixmap()
        self.message = "Loading local radar loop…"

        self.setMinimumSize(390, 380)

    def set_frame(self, pixmap):
        self.pixmap = pixmap
        self.message = ""
        self.update()

    def set_message(self, message):
        self.pixmap = QPixmap()
        self.message = message
        self.update()

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.fillRect(self.rect(), QColor("#d8e7ea"))

        if self.pixmap.isNull():
            painter.setPen(QColor("#263238"))
            painter.drawText(
                self.rect().adjusted(24, 24, -24, -24),
                Qt.AlignCenter | Qt.TextWordWrap,
                self.message,
            )
            return

        target = self.rect().adjusted(6, 6, -6, -6)

        scaled = self.pixmap.scaled(
            target.size(),
            Qt.KeepAspectRatio,
            Qt.SmoothTransformation,
        )

        x = target.x() + int((target.width() - scaled.width()) / 2)
        y = target.y() + int((target.height() - scaled.height()) / 2)

        painter.drawPixmap(x, y, scaled)


class RadarTimelineView(QWidget):
    def __init__(self):
        super().__init__()

        self.frame_times = []
        self.current_index = 0

        self.setMinimumHeight(78)
        self.setMaximumHeight(78)

    def set_frames(self, frames, local_zone):
        self.frame_times = []

        for frame in frames or []:
            value = frame.get("valid_time")

            if value is not None:
                self.frame_times.append(
                    value.astimezone(local_zone)
                )

        self.current_index = 0
        self.update()

    def set_current_index(self, index):
        self.current_index = max(0, int(index))
        self.update()

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.Antialiasing, True)

        rect = self.rect().adjusted(10, 4, -10, -4)

        painter.fillRect(
            self.rect(),
            QColor(246, 228, 189, 120),
        )

        if not self.frame_times:
            painter.setPen(QColor("#5b4128"))
            painter.setFont(QFont("American Typewriter", 10, QFont.Bold))
            painter.drawText(
                rect,
                Qt.AlignCenter,
                "Preparing radar timeline…",
            )
            return

        count = len(self.frame_times)
        line_y = 25
        left_x = rect.left() + 8
        right_x = rect.right() - 8

        painter.setPen(QPen(QColor("#5a3c21"), 2))
        painter.drawLine(left_x, line_y, right_x, line_y)

        if count == 1:
            positions = [int((left_x + right_x) / 2)]
        else:
            positions = [
                int(
                    left_x
                    + ((right_x - left_x) * index / (count - 1))
                )
                for index in range(count)
            ]

        current_index = min(
            self.current_index,
            len(positions) - 1,
        )

        for index, x in enumerate(positions):
            is_current = index == current_index

            if is_current:
                painter.setPen(QPen(QColor("#211308"), 2))
                painter.setBrush(QColor("#f8ebcb"))
                painter.drawEllipse(x - 6, line_y - 6, 12, 12)

                painter.setPen(QPen(QColor("#211308"), 2))
                painter.drawLine(x, 4, x, line_y - 8)

                painter.setBrush(QColor("#211308"))
                painter.drawPolygon(
                    [
                        (x - 4, 5),
                        (x + 4, 5),
                        (x, 11),
                    ]
                )
            else:
                painter.setPen(QPen(QColor("#684723"), 1))
                painter.setBrush(QColor("#f6e4bd"))
                painter.drawEllipse(x - 3, line_y - 3, 6, 6)

            painter.setPen(QPen(QColor("#684723"), 1))
            painter.drawLine(x, line_y + 5, x, line_y + 10)

        font_size = 9 if count <= 9 else 7
        label_font = QFont("American Typewriter", font_size)
        label_font.setBold(False)

        active_font = QFont("American Typewriter", font_size)
        active_font.setBold(True)

        for index, (x, frame_time) in enumerate(
            zip(positions, self.frame_times)
        ):
            is_current = index == current_index
            label = frame_time.strftime("%-I:%M")

            painter.setFont(active_font if is_current else label_font)
            painter.setPen(
                QColor("#211308") if is_current else QColor("#684723")
            )

            text_width = painter.fontMetrics().horizontalAdvance(label)

            painter.drawText(
                int(x - (text_width / 2)),
                55,
                label,
            )

        painter.setFont(QFont("American Typewriter", 8))
        painter.setPen(QColor("#765637"))
        painter.drawText(
            rect.adjusted(0, 58, 0, 0),
            Qt.AlignCenter,
            "RADAR FRAME TIMELINE",
        )


class RadarFetchWorker(QThread):
    ready = Signal(object)
    failed = Signal(str)

    def __init__(self, latitude, longitude, selected_start_utc):
        super().__init__()

        self.latitude = latitude
        self.longitude = longitude
        self.selected_start_utc = selected_start_utc

    def run(self):
        try:
            from services.weather_radar_fetcher import (
                fetch_weathercom_radar_frames,
            )

            frames = fetch_weathercom_radar_frames(
                latitude=self.latitude,
                longitude=self.longitude,
                selected_start_utc=self.selected_start_utc,
            )

            self.ready.emit(frames)

        except Exception as error:
            self.failed.emit(str(error))


class WeatherRadarDialog(QDialog):
    def __init__(self, weather_row, row_index, location, parent=None):
        super().__init__(parent)

        self.weather_row = weather_row
        self.location = location
        self.frames = []
        self.pixmaps = []
        self.frame_index = 0
        self.worker = None
        self.is_playing = True

        self.local_zone = ZoneInfo(
            getattr(location, "timezone", "America/New_York")
        )

        forecast_start = str(
            getattr(weather_row, "forecast_start", "") or ""
        ).strip()

        try:
            parsed_start = datetime.fromisoformat(
                forecast_start.replace("Z", "+00:00")
            )

            if parsed_start.tzinfo is None:
                parsed_start = parsed_start.replace(
                    tzinfo=self.local_zone
                )
            else:
                parsed_start = parsed_start.astimezone(self.local_zone)

            self.selected_start_local = parsed_start.replace(
                minute=0,
                second=0,
                microsecond=0,
            )

        except Exception:
            now_local = datetime.now(self.local_zone).replace(
                minute=0,
                second=0,
                microsecond=0,
            )

            self.selected_start_local = now_local + timedelta(
                hours=int(row_index)
            )

        self.selected_start_utc = self.selected_start_local.astimezone(
            ZoneInfo("UTC")
        )

        self.setWindowTitle("Local Radar")
        self.setModal(False)
        self.setWindowFlags(Qt.Widget | Qt.FramelessWindowHint)
        self.setAttribute(Qt.WA_StyledBackground, True)
        self.resize(1120, 650)

        self.setStyleSheet("""
            QDialog {
                background-color: #2d2419;
            }

            QLabel#RadarMasthead {
                font-family: "Rockwell", "Georgia", serif;
                font-size: 27px;
                font-weight: 1000;
                color: #24170d;
                letter-spacing: 1.2px;
                background: transparent;
            }

            QLabel#RadarPageTitle {
                font-family: "Georgia";
                font-size: 19px;
                font-weight: 1000;
                color: #1b130c;
                background: transparent;
            }

            QLabel#RadarMeta,
            QLabel#RadarDetail {
                font-family: "American Typewriter", "Courier New", monospace;
                font-size: 15px;
                font-weight: 700;
                color: #1b130c;
                background: transparent;
            }

            QWidget#RadarLoopView {
                background: #d8e7ea;
                border: 1px solid rgba(70, 50, 28, 160);
            }

            QPushButton#RadarControlButton,
            QPushButton#RadarCloseButton {
                background-color: #f3e6c9;
                border: 2px solid rgba(70, 50, 28, 210);
                border-radius: 5px;
                color: #24170d;
                font-family: "Georgia";
                font-size: 16px;
                font-weight: 1000;
                padding: 6px 13px;
                min-width: 82px;
                min-height: 31px;
            }

            QPushButton#RadarControlButton:hover,
            QPushButton#RadarCloseButton:hover {
                background-color: #fff0cf;
            }

            QPushButton#RadarCloseButton {
                min-width: 120px;
            }
        """)

        root = QVBoxLayout(self)
        root.setContentsMargins(18, 16, 18, 16)
        root.setSpacing(10)

        header = QHBoxLayout()

        masthead = QLabel("LOCAL RADAR MAP")
        masthead.setObjectName("RadarMasthead")

        self.status_label = QLabel("Preparing Weather.com radar frames…")
        self.status_label.setStyleSheet("""
            QLabel {
                color: #e8d8b6;
                font-family: "Times New Roman";
                font-size: 13px;
                font-weight: 900;
                letter-spacing: 1px;
                background: transparent;
            }
        """)
        self.status_label.setAlignment(Qt.AlignRight | Qt.AlignVCenter)

        header.addWidget(masthead, 1)
        header.addWidget(self.status_label)
        root.addLayout(header)

        surface = RadarPaperSurface()
        surface_layout = QHBoxLayout(surface)
        surface_layout.setContentsMargins(20, 14, 20, 12)
        surface_layout.setSpacing(14)

        left_page = QWidget()
        left_layout = QVBoxLayout(left_page)
        left_layout.setContentsMargins(0, 0, 0, 0)
        left_layout.setSpacing(8)

        left_title = QLabel("RADAR LOOP • ROADS • TOWNS")
        left_title.setObjectName("RadarPageTitle")

        self.radar_view = RadarLoopView()
        self.radar_view.setObjectName("RadarLoopView")

        self.radar_timeline = RadarTimelineView()
        self.radar_timeline.setObjectName("RadarTimelineView")

        self.radar_time_label = QLabel("")
        self.radar_time_label.setObjectName("RadarMeta")
        self.radar_time_label.setAlignment(Qt.AlignCenter)

        left_layout.addWidget(left_title)
        left_layout.addWidget(self.radar_view, 1)
        left_layout.addWidget(self.radar_timeline)
        left_layout.addWidget(self.radar_time_label)

        right_page = QWidget()
        right_layout = QVBoxLayout(right_page)
        right_layout.setContentsMargins(10, 0, 0, 0)
        right_layout.setSpacing(12)

        right_title = QLabel("SELECTED FORECAST HOUR")
        right_title.setObjectName("RadarPageTitle")
        right_layout.addWidget(right_title)

        location_label = getattr(location, "label", "") or "Saved location"
        selected_end = self.selected_start_local + timedelta(
            minutes=90
        )

        precipitation_probability = getattr(
            weather_row,
            "precipitation_probability",
            None,
        )

        precipitation_text = (
            f"{precipitation_probability}%"
            if precipitation_probability is not None
            else "Not available"
        )

        details = [
            f"LOCATION\n{location_label}",
            (
                "TIME WINDOW\n"
                f"{self.selected_start_local.strftime('%A, %-I:00 %p')} to "
                f"{selected_end.strftime('%-I:00 %p')}"
            ),
            f"TEMPERATURE\n{getattr(weather_row, 'temperature', '--')}°",
            (
                "CONDITION\n"
                f"{str(getattr(weather_row, 'condition', 'unknown')).upper()}"
            ),
            f"PRECIPITATION CHANCE\n{precipitation_text}",
            f"WIND\n{getattr(weather_row, 'wind_speed', '') or 'Not available'}",
            "RADAR TYPE\nWEATHER.COM RADAR",
            (
                "NOTE\nFuture selected hours use Weather.com predicted "
                "radar frames. Past and current hours use observed radar."
            ),
        ]

        for detail in details:
            label = QLabel(detail)
            label.setObjectName("RadarDetail")
            label.setWordWrap(True)
            label.setAlignment(Qt.AlignLeft | Qt.AlignTop)
            right_layout.addWidget(label)

            rule = QFrame()
            rule.setFrameShape(QFrame.HLine)
            rule.setFixedHeight(1)
            rule.setStyleSheet(
                "background-color: rgba(90, 78, 63, 135); border: none;"
            )
            right_layout.addWidget(rule)

        right_layout.addStretch(1)

        surface_layout.addWidget(left_page, 1)
        surface_layout.addWidget(right_page, 1)
        root.addWidget(surface, 1)

        controls = QHBoxLayout()
        controls.addStretch(1)

        self.previous_button = QPushButton("◀")
        self.previous_button.setObjectName("RadarControlButton")
        self.previous_button.clicked.connect(self.previous_frame)

        self.play_button = QPushButton("PAUSE")
        self.play_button.setObjectName("RadarControlButton")
        self.play_button.clicked.connect(self.toggle_playback)

        self.next_button = QPushButton("▶")
        self.next_button.setObjectName("RadarControlButton")
        self.next_button.clicked.connect(self.next_frame)

        close_button = QPushButton("CLOSE")
        close_button.setObjectName("RadarCloseButton")
        close_button.clicked.connect(self.close)

        controls.addWidget(self.previous_button)
        controls.addWidget(self.play_button)
        controls.addWidget(self.next_button)
        controls.addSpacing(20)
        controls.addWidget(close_button)
        controls.addStretch(1)

        root.addLayout(controls)

        self.animation_timer = QTimer(self)
        self.animation_timer.setInterval(420)
        self.animation_timer.timeout.connect(self.next_frame)

        self.start_fetch()

    def start_fetch(self):
        self.worker = RadarFetchWorker(
            latitude=self.location.latitude,
            longitude=self.location.longitude,
            selected_start_utc=self.selected_start_utc,
        )

        self.worker.ready.connect(self.apply_frames)
        self.worker.failed.connect(self.show_error)
        self.worker.finished.connect(self.worker.deleteLater)
        self.worker.start()

    def apply_frames(self, frames):
        incoming_frames = list(frames or [])
        self.frames = []
        self.pixmaps = []

        for frame in incoming_frames:
            pixmap = QPixmap()

            if pixmap.loadFromData(frame.get("image_bytes", b"")):
                self.frames.append(frame)
                self.pixmaps.append(pixmap)

        if len(self.pixmaps) < 4:
            self.show_error("Weather.com did not return enough radar images.")
            return

        self.frame_index = 0
        self.radar_timeline.set_frames(
            self.frames,
            self.local_zone,
        )
        self.show_frame()

        radar_types = {
            str(frame.get("radar_type", "")).strip()
            for frame in self.frames
        }

        if len(radar_types) > 1:
            status_text = "Observed + predicted radar"
        else:
            status_text = next(
                iter(radar_types),
                "Weather.com radar",
            ).title()

        self.status_label.setText(
            f"{status_text} — cached locally for 5 minutes"
        )

        self.is_playing = True
        self.play_button.setText("PAUSE")
        self.animation_timer.start()

    def show_frame(self):
        if not self.pixmaps or not self.frames:
            return

        self.frame_index %= len(self.pixmaps)

        self.radar_view.set_frame(self.pixmaps[self.frame_index])
        self.radar_timeline.set_current_index(self.frame_index)

        frame_time = self.frames[self.frame_index]["valid_time"]
        frame_time = frame_time.astimezone(self.local_zone)

        radar_type = str(
            self.frames[self.frame_index].get(
                "radar_type",
                "WEATHER.COM RADAR",
            )
        ).title()

        self.radar_time_label.setText(
            f"Radar frame {self.frame_index + 1} of {len(self.pixmaps)}"
            f"  •  {frame_time.strftime('%-I:%M %p')}"
            f"  •  {radar_type}"
            "  •  Mapbox © OpenStreetMap"
        )

    def next_frame(self):
        if not self.pixmaps:
            return

        self.frame_index = (self.frame_index + 1) % len(self.pixmaps)
        self.show_frame()

    def previous_frame(self):
        if not self.pixmaps:
            return

        self.frame_index = (self.frame_index - 1) % len(self.pixmaps)
        self.show_frame()

    def toggle_playback(self):
        self.is_playing = not self.is_playing

        if self.is_playing:
            self.play_button.setText("PAUSE")
            self.animation_timer.start()
        else:
            self.play_button.setText("PLAY")
            self.animation_timer.stop()

    def show_error(self, message):
        self.animation_timer.stop()
        self.status_label.setText("Radar loop unavailable")
        self.radar_time_label.setText("")
        self.radar_view.set_message(message)

    def closeEvent(self, event):
        self.animation_timer.stop()

        try:
            if self.worker and self.worker.isRunning():
                self.worker.wait(1500)
        except RuntimeError:
            pass

        super().closeEvent(event)
