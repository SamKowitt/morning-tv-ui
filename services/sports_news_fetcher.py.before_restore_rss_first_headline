import html
import json
import re
import ssl
import urllib.request
import xml.etree.ElementTree as ET
from dataclasses import dataclass

import certifi


@dataclass
class SportsArticle:
    title: str
    link: str = ""
    category: str = "ESPN"


SSL_CONTEXT = ssl.create_default_context(cafile=certifi.where())

ESPN_NEWS_API = "https://site.api.espn.com/apis/site/v2/sports/soccer/news?limit=20"

ESPN_FEEDS = [
    "https://www.espn.com/espn/rss/news",
    "http://sports.espn.go.com/espn/rss/news",
]


def clean_text(value):
    if not value:
        return ""

    value = html.unescape(str(value))
    value = re.sub(r"<[^>]+>", " ", value)
    value = re.sub(r"\s+", " ", value).strip()
    return value


def get_child_text(item, tag_name):
    for child in item:
        if child.tag.lower().endswith(tag_name.lower()):
            return clean_text(child.text or "")
    return ""


def fetch_espn_api_articles(max_articles=4):
    request = urllib.request.Request(
        ESPN_NEWS_API,
        headers={
            "User-Agent": "Mozilla/5.0 MorningTVUI/1.0",
            "Accept": "application/json, text/plain, */*",
        },
    )

    with urllib.request.urlopen(
        request,
        timeout=12,
        context=SSL_CONTEXT,
    ) as response:
        payload = json.loads(response.read().decode("utf-8", errors="replace"))

    raw_articles = payload.get("articles", [])
    articles = []

    for item in raw_articles:
        title = clean_text(item.get("headline", ""))
        link = clean_text(item.get("links", {}).get("web", {}).get("href", ""))

        if not title or not link:
            continue

        category = clean_text(
            item.get("categories", [{}])[0].get("description", "")
            if item.get("categories")
            else ""
        ) or "ESPN"

        articles.append(
            SportsArticle(
                title=title,
                link=link,
                category=category.upper(),
            )
        )

        if len(articles) >= max_articles:
            break

    return articles


def fetch_espn_sports_articles(max_articles=4):
    try:
        print(f"Trying ESPN sports news API: {ESPN_NEWS_API}")
        articles = fetch_espn_api_articles(max_articles=max_articles)

        if articles:
            print(f"Loaded ESPN API sports stories: {len(articles)}")
            return articles

    except Exception as error:
        print(f"ESPN sports API failed: {error}")

    errors = []

    for feed_url in ESPN_FEEDS:
        try:
            print(f"Trying ESPN sports feed: {feed_url}")
            articles = fetch_espn_rss(feed_url, max_articles=max_articles)

            if articles:
                print(f"Loaded ESPN sports stories from RSS: {len(articles)}")
                return articles

        except Exception as error:
            message = f"{feed_url} -> {error}"
            print(f"ESPN sports feed failed: {message}")
            errors.append(message)

    print(f"All ESPN sports sources failed: {' | '.join(errors)}")
    return fallback_articles()


def fetch_espn_rss(feed_url, max_articles=4):
    request = urllib.request.Request(
        feed_url,
        headers={
            "User-Agent": "Mozilla/5.0 MorningTVUI/1.0",
            "Accept": "application/rss+xml, application/xml, text/xml, */*",
        },
    )

    with urllib.request.urlopen(
        request,
        timeout=12,
        context=SSL_CONTEXT,
    ) as response:
        xml_data = response.read()

    root = ET.fromstring(xml_data)
    items = root.findall(".//item")
    articles = []

    for item in items:
        title = get_child_text(item, "title")
        link = get_child_text(item, "link")

        if not title:
            continue

        category = get_child_text(item, "category") or "ESPN"

        articles.append(
            SportsArticle(
                title=title,
                link=link,
                category=category.upper(),
            )
        )

        if len(articles) >= max_articles:
            break

    return articles


def fallback_articles():
    return [
        SportsArticle("Unable to load ESPN sports headlines.", "", "ESPN"),
        SportsArticle(
            "Check your internet connection or ESPN RSS availability.",
            "",
            "ESPN",
        ),
        SportsArticle(
            "Sports news panel will keep using fallback stories.",
            "",
            "ESPN",
        ),
        SportsArticle("Try running the app again later.", "", "ESPN"),
    ]
