def date_is_between(month_day, start_month_day, end_month_day):
    """
    Inclusive month/day comparison that supports seasons crossing New Year.
    Values are tuples like (8, 1).
    """
    if start_month_day <= end_month_day:
        return start_month_day <= month_day <= end_month_day

    return month_day >= start_month_day or month_day <= end_month_day


def league_is_in_primary_season(league, current_date=None):
    if current_date is None:
        current_date = datetime.now(LOCAL_TIMEZONE).date()

    month_day = (current_date.month, current_date.day)

    if league == "MLB":
        return date_is_between(month_day, (4, 1), (10, 28))

    if league == "NFL":
        return date_is_between(month_day, (8, 1), (2, 15))

    if league == "NBA":
        return date_is_between(month_day, (10, 7), (6, 14))

    return False


def league_has_usable_game_in_next_days(
    league,
    lookahead_days=OFFSEASON_LOOKAHEAD_DAYS,
):
    """
    Off-season fallback: return True only when a league has at least one
    usable game today or within the next two calendar days.
    """
    today = datetime.now(LOCAL_TIMEZONE).date()
    end_date = today + timedelta(days=lookahead_days - 1)

    if league == "MLB":
        try:
            data = fetch_json(build_mlb_schedule_url(today, end_date))
        except Exception as error:
            print(f"MLB fallback schedule check failed: {error}")
            return False

        for date_block in data.get("dates", []) or []:
            for game in date_block.get("games", []) or []:
                if not should_include_mlb_game(game):
                    continue

                game_date = get_game_local_date(game.get("gameDate"))

                if game_date and today <= game_date <= end_date:
                    return True

        return False

    if league not in ESPN_SCOREBOARD_ENDPOINTS:
        return False

    for day_offset in range(lookahead_days):
        date_value = today + timedelta(days=day_offset)

        try:
            events = fetch_espn_events_for_day(league, date_value)
        except Exception as error:
            print(
                f"{league} fallback schedule check failed for "
                f"{date_value:%Y-%m-%d}: {error}"
            )
            continue

        for event in events:
            # Rejects cancelled, postponed, delayed, suspended, forfeited,
            # and STATUS_UNNECESSARY events.
            if not should_include_espn_event(event):
                continue

            event_date = get_game_local_date(event.get("date"))

            if event_date and today <= event_date <= end_date:
                return True

    return False


