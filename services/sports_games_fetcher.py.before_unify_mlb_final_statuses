LOCAL_TIMEZONE = ZoneInfo("America/New_York")

OFFSEASON_LOOKAHEAD_DAYS = 3

BOXSCORE_CACHE_TTL_SECONDS = 300
_boxscore_cache = {}
_boxscore_cache_lock = threading.Lock()


def _boxscore_cache_key(league, game_id):
    return f"{str(league or '').upper()}:{str(game_id or '').strip()}"


def get_cached_boxscore(league, game_id):
    key = _boxscore_cache_key(league, game_id)

    with _boxscore_cache_lock:
        entry = _boxscore_cache.get(key)

        if not entry:
            return None

        cached_at, payload = entry

        if time.monotonic() - cached_at >= BOXSCORE_CACHE_TTL_SECONDS:
            return None

        return payload


def _store_cached_boxscore(league, game_id, payload):
    key = _boxscore_cache_key(league, game_id)

    with _boxscore_cache_lock:
        _boxscore_cache[key] = (time.monotonic(), payload)

    return payload

