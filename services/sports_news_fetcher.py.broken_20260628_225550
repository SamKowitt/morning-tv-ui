import html
import re
import ssl
import time
import urllib.request
import xml.etree.ElementTree as ET
from dataclasses import dataclass

import certifi

from services.newsmax_chrome import _close_page, _create_page, _eval, _navigate


@dataclass
class SportsArticle:
    title: str
    link: str = ""
    category: str = "ESPN"


SSL_CONTEXT = ssl.create_default_context(cafile=certifi.where())

ESPN_HOMEPAGE = "https://www.espn.com/"

ESPN_FEEDS = [
    "https://www.espn.com/espn/rss/news",
    "http://sports.espn.go.com/espn/rss/news",
]


def clean_text(value):
    if not value:
        return ""

    value = html.unescape(str(value))
    value = re.sub(r"<[^>]+>", " ", value)
    value = re.sub(r"\s+", " ", value).strip()
    return value


def get_child_text(item, tag_name):
    for child in item:
        if child.tag.lower().endswith(tag_name.lower()):
            return clean_text(child.text or "")
    return ""


def is_valid_article(article):
    return bool(
        article
        and clean_text(article.title)
        and str(article.link or "").startswith("http")
    )



def fetch_espn_homepage_lead():
    """
    Select ESPN's lead from the physically largest visible editorial text on
    the rendered homepage. Ranking uses actual rendered text geometry, not
    CSS class names, DOM containers, or pre-filtered ESPN URL patterns.
    """
    target_id = ""
    ws_url = ""

    try:
        target_id, ws_url = _create_page()
        _navigate(ws_url, ESPN_HOMEPAGE)

        previous_titles = ""
        stable_passes = 0

        for _ in range(12):
            current_titles = _eval(
                ws_url,
                r"""
(() => Array.from(document.querySelectorAll("a[href]"))
    .map(node => (node.innerText || node.textContent || "").replace(/\s+/g, " ").trim())
    .filter(text => text.length >= 18)
    .slice(0, 120)
    .join(" | "))()
""",
                timeout=8,
            )

            current_titles = str(current_titles or "")

            if current_titles and current_titles == previous_titles:
                stable_passes += 1
            else:
                stable_passes = 0
                previous_titles = current_titles

            if stable_passes >= 2:
                break

            time.sleep(0.75)

        payload = _eval(
            ws_url,
            r"""
(() => {
    const clean = value => String(value || "")
        .replace(/\s+/g, " ")
        .trim();

    const blockedTextBits = [
        "scores",
        "schedule",
        "standings",
        "teams",
        "watch",
        "listen",
        "search",
        "menu",
        "sign in",
        "subscribe",
        "advertisement",
        "privacy",
        "terms",
        "fantasy",
        "espn bet",
        "skip to"
    ];

    const blockedHrefBits = [
        "/video/",
        "/watch/",
        "/espnplus/",
        "/fantasy/",
        "/betting/",
        "/tickets/",
        "/radio/",
        "/scoreboard",
        "/schedule",
        "/standings"
    ];

    const isVisibleElement = element => {
        if (!element || element.nodeType !== Node.ELEMENT_NODE) {
            return false;
        }

        const style = window.getComputedStyle(element);
        const rect = element.getBoundingClientRect();

        return (
            style.display !== "none" &&
            style.visibility !== "hidden" &&
            Number(style.opacity || 1) > 0 &&
            rect.width > 3 &&
            rect.height > 3
        );
    };

    const normalizeHref = href => {
        const value = String(href || "").trim();

        if (!value) {
            return "";
        }

        try {
            return new URL(value, location.href).href;
        } catch {
            return "";
        }
    };

    const isUsableArticleLink = (href, allowVideo = false) => {
        const value = String(href || "").toLowerCase();

        if (!value.includes("espn.com/")) {
            return false;
        }

        if (allowVideo) {
            return value.includes("/video/clip/_/id/");
        }

        if (blockedHrefBits.some(bit => value.includes(bit))) {
            return false;
        }

        return (
            value.includes("/story/") ||
            value.includes("/report/") ||
            /\/20\d{2}\//.test(value) ||
            /\/id\/\d+/.test(value)
        );
    };

    const walker = document.createTreeWalker(
        document.body,
        NodeFilter.SHOW_TEXT,
        {
            acceptNode(node) {
                const value = clean(node.nodeValue || "");

                if (value.length < 18 || value.length > 260) {
                    return NodeFilter.FILTER_REJECT;
                }

                const parent = node.parentElement;

                if (!isVisibleElement(parent)) {
                    return NodeFilter.FILTER_REJECT;
                }

                const tag = String(parent.tagName || "").toUpperCase();

                if (
                    ["SCRIPT", "STYLE", "NOSCRIPT", "SVG", "OPTION"].includes(tag)
                ) {
                    return NodeFilter.FILTER_REJECT;
                }

                return NodeFilter.FILTER_ACCEPT;
            }
        }
    );

    const candidates = [];
    const seen = new Set();

    let textNode;

    while ((textNode = walker.nextNode())) {
        const title = clean(textNode.nodeValue || "");
        const titleLower = title.toLowerCase();

        if (
            blockedTextBits.some(bit => (
                titleLower === bit ||
                titleLower.startsWith(bit + " ") ||
                titleLower.includes(" " + bit + " ")
            ))
        ) {
            continue;
        }

        const parent = textNode.parentElement;

        const card = parent.closest(
            "section.contentItem, article, [class*='contentItem' i], "
            + "[class*='story' i], [class*='card' i]"
        );

        const videoButton = card
            ? card.querySelector("[data-popup-href]")
            : null;

        const videoHref = normalizeHref(
            videoButton?.getAttribute("data-popup-href")
        );

        let href = "";
        let isVideo = false;

        if (videoHref && isUsableArticleLink(videoHref, true)) {
            href = videoHref;
            isVideo = true;
        } else {
            let link = parent.closest("a[href]");

            if (!link && card) {
                link = card.querySelector("a[href]");
            }

            href = normalizeHref(link?.href);

            if (!isUsableArticleLink(href)) {
                continue;
            }
        }

        const range = document.createRange();
        range.selectNodeContents(textNode);

        const rects = Array.from(range.getClientRects()).filter(rect => (
            rect.width > 2 &&
            rect.height > 2
        ));

        if (!rects.length) {
            continue;
        }

        const visibleRects = rects.filter(rect => (
            rect.bottom > 0 &&
            rect.top < window.innerHeight &&
            rect.right > 0 &&
            rect.left < window.innerWidth
        ));

        const usableRects = visibleRects.length ? visibleRects : rects;

        const renderedArea = usableRects.reduce(
            (total, rect) => total + (rect.width * rect.height),
            0
        );

        const maxLineHeight = Math.max(
            ...usableRects.map(rect => rect.height)
        );

        const maxLineWidth = Math.max(
            ...usableRects.map(rect => rect.width)
        );

        const top = Math.min(
            ...usableRects.map(rect => rect.top)
        );

        const left = Math.min(
            ...usableRects.map(rect => rect.left)
        );

        const style = window.getComputedStyle(parent);
        const fontSize = parseFloat(style.fontSize) || 0;
        const fontWeight = parseInt(style.fontWeight, 10) || 0;

        const key = `${title}|${href}`;

        if (seen.has(key)) {
            continue;
        }

        seen.add(key);

        candidates.push({
            title,
            link: href,
            renderedArea: Math.round(renderedArea),
            maxLineHeight: Math.round(maxLineHeight * 100) / 100,
            maxLineWidth: Math.round(maxLineWidth),
            fontSize,
            fontWeight,
            top: Math.round(top),
            left: Math.round(left),
            tag: parent.tagName,
            className: String(parent.className || "").slice(0, 180),
            isVideo
        });
    }

    candidates.sort((a, b) => (
        b.maxLineHeight - a.maxLineHeight ||
        b.renderedArea - a.renderedArea ||
        b.maxLineWidth - a.maxLineWidth ||
        b.fontWeight - a.fontWeight ||
        a.top - b.top ||
        a.left - b.left
    ));

    return {
        count: candidates.length,
        selected: candidates[0] || null,
        topCandidates: candidates.slice(0, 30)
    };
})()
""",
            timeout=25,
        )

        if not isinstance(payload, dict):
            raise RuntimeError("Chrome did not return ESPN homepage data")

        print("\n===== ESPN TRUE VISIBLE-TEXT CANDIDATES =====")
        for index, candidate in enumerate(
            payload.get("topCandidates", []) or [],
            start=1,
        ):
            print(
                f"{index}. glyph_height={candidate.get('maxLineHeight')}px "
                f"glyph_area={candidate.get('renderedArea')} "
                f"width={candidate.get('maxLineWidth')} "
                f"top={candidate.get('top')} "
                f"tag={candidate.get('tag')}"
            )
            print(f"   title={candidate.get('title')}")
            print(f"   link={candidate.get('link')}")

        selected = payload.get("selected") or {}
        title = clean_text(selected.get("title", ""))
        link = str(selected.get("link", "") or "").strip()

        if not title or not link:
            raise RuntimeError(
                "No usable ESPN visible-text headline found. "
                f"Candidates seen: {payload.get('count', 0)}"
            )

        article = SportsArticle(
            title=title,
            link=link,
            category="ESPN",
        )

        print(
            "ESPN TRUE LARGEST VISIBLE TEXT LEAD: "
            f'"{article.title}" '
            f'(glyph_height={selected.get("maxLineHeight", 0)}px, '
            f'glyph_area={selected.get("renderedArea", 0)})'
        )
        print(f"ESPN TRUE VISIBLE-TEXT LEAD LINK: {article.link}")

        return article

    finally:
        if target_id:
            _close_page(target_id)

def resolve_truncated_espn_title(article):
    """
    ESPN RSS sometimes shortens headlines with "...".
    Load only those affected article pages and recover the full visible title.
    """
    original_title = clean_text(getattr(article, "title", ""))
    article_url = str(getattr(article, "link", "") or "").strip()

    if not original_title.endswith("...") or not article_url:
        return original_title

    target_id = ""
    ws_url = ""

    try:
        target_id, ws_url = _create_page()
        _navigate(ws_url, article_url)

        payload = _eval(
            ws_url,
            r"""
(() => {
    const clean = value => String(value || "")
        .replace(/\s+/g, " ")
        .replace(/\s+\|\s+ESPN$/i, "")
        .replace(/\s+-\s+ESPN$/i, "")
        .trim();

    const h1 = document.querySelector("h1");
    const ogTitle = document.querySelector('meta[property="og:title"]');
    const twitterTitle = document.querySelector('meta[name="twitter:title"]');

    return {
        h1: clean(h1 ? (h1.innerText || h1.textContent) : ""),
        ogTitle: clean(ogTitle ? ogTitle.content : ""),
        twitterTitle: clean(twitterTitle ? twitterTitle.content : ""),
        documentTitle: clean(document.title || "")
    };
})()
""",
            timeout=20,
        )

        if not isinstance(payload, dict):
            return original_title

        candidates = [
            clean_text(payload.get("h1", "")),
            clean_text(payload.get("ogTitle", "")),
            clean_text(payload.get("twitterTitle", "")),
            clean_text(payload.get("documentTitle", "")),
        ]

        for candidate in candidates:
            if len(candidate) >= 20 and not candidate.endswith("..."):
                print(
                    "EXPANDED ESPN RSS TITLE: "
                    f"{original_title} -> {candidate}"
                )
                return candidate

    except Exception as error:
        print(f"Could not expand ESPN RSS title: {original_title} -> {error}")

    finally:
        if target_id:
            _close_page(target_id)

    return original_title

def fetch_espn_sports_articles(max_articles=4):
    """
    Use ESPN's rendered largest-text homepage headline as Sports Desk lead,
    then fill the remaining slots from ESPN RSS editorial stories.
    """
    articles = []
    used_links = set()
    errors = []

    try:
        lead = fetch_espn_homepage_lead()

        if is_valid_article(lead):
            articles.append(lead)
            used_links.add(lead.link.rstrip("/").lower())
    except Exception as error:
        message = f"homepage lead -> {error}"
        print(f"ESPN homepage lead failed: {message}")
        errors.append(message)

    for feed_url in ESPN_FEEDS:
        try:
            print(f"Trying ESPN sports feed: {feed_url}")
            rss_articles = fetch_espn_rss(feed_url, max_articles=30)

            for article in rss_articles:
                if not is_valid_article(article):
                    continue

                normalized_link = article.link.rstrip("/").lower()

                is_editorial_story = "/story/_/id/" in normalized_link
                is_match_report = "/report/_/gameid/" in normalized_link

                if not (is_editorial_story or is_match_report):
                    print(
                        "Skipping non-article ESPN feed entry: "
                        f"{article.title} -> {article.link}"
                    )
                    continue

                if normalized_link in used_links:
                    continue

                article.title = resolve_truncated_espn_title(article)

                articles.append(article)
                used_links.add(normalized_link)

                if len(articles) >= max_articles:
                    print(
                        "Loaded ESPN Sports Desk stories "
                        f"(rendered lead + RSS): {len(articles)}"
                    )
                    return articles[:max_articles]

        except Exception as error:
            message = f"{feed_url} -> {error}"
            print(f"ESPN sports feed failed: {message}")
            errors.append(message)

    if articles:
        print(f"Loaded partial ESPN Sports Desk stories: {len(articles)}")
        return articles[:max_articles]

    print(f"All ESPN sports sources failed: {' | '.join(errors)}")
    return fallback_articles()

def fetch_espn_rss(feed_url, max_articles=20):
    request = urllib.request.Request(
        feed_url,
        headers={
            "User-Agent": "Mozilla/5.0 MorningTVUI/1.0",
            "Accept": "application/rss+xml, application/xml, text/xml, */*",
        },
    )

    with urllib.request.urlopen(
        request,
        timeout=12,
        context=SSL_CONTEXT,
    ) as response:
        xml_data = response.read()

    root = ET.fromstring(xml_data)
    items = root.findall(".//item")
    articles = []

    for item in items:
        title = get_child_text(item, "title")
        link = get_child_text(item, "link")

        if not title or not link:
            continue

        category = get_child_text(item, "category") or "ESPN"

        articles.append(
            SportsArticle(
                title=title,
                link=link,
                category=category.upper(),
            )
        )

        if len(articles) >= max_articles:
            break

    return articles


def fallback_articles():
    return [
        SportsArticle("Unable to load ESPN sports headlines.", "", "ESPN"),
        SportsArticle(
            "Check your internet connection or ESPN RSS availability.",
            "",
            "ESPN",
        ),
        SportsArticle(
            "Sports news panel will keep using fallback stories.",
            "",
            "ESPN",
        ),
        SportsArticle("Try running the app again later.", "", "ESPN"),
    ]
