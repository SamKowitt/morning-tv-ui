import io
import ssl
import urllib.parse
import urllib.request
from datetime import datetime, timedelta, timezone
from pathlib import Path

import certifi
import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt
import numpy as np
import xarray as xr


SSL_CONTEXT = ssl.create_default_context(cafile=certifi.where())
CACHE_DIR = Path.home() / ".cache" / "MorningTVUI" / "hrrr_radar"
CACHE_DIR.mkdir(parents=True, exist_ok=True)


def _latest_available_cycle(target_utc):
    """
    HRRR files are normally available shortly after their cycle begins.
    Using two hours behind current UTC avoids requesting a run that is still
    publishing while retaining a useful short-range forecast.
    """
    now_utc = datetime.now(timezone.utc).replace(
        minute=0,
        second=0,
        microsecond=0,
    )
    cycle = now_utc - timedelta(hours=2)

    if target_utc < cycle:
        cycle = target_utc - timedelta(hours=2)

    return cycle.replace(minute=0, second=0, microsecond=0)


def _download_reflectivity_grib(latitude, longitude, target_utc):
    target_utc = target_utc.astimezone(timezone.utc)
    cycle = _latest_available_cycle(target_utc)

    forecast_hour = max(
        0,
        min(
            18,
            int(round((target_utc - cycle).total_seconds() / 3600)),
        ),
    )

    valid_time = cycle + timedelta(hours=forecast_hour)
    cache_name = (
        f"hrrr_refc_{cycle:%Y%m%d_%H}_f{forecast_hour:02d}_"
        f"{latitude:.3f}_{longitude:.3f}.grib2"
    )
    output = CACHE_DIR / cache_name

    if output.exists() and output.stat().st_size > 1000:
        return output, valid_time

    lat_padding = 0.58
    lon_padding = 0.78

    params = {
        "file": f"hrrr.t{cycle:%H}z.wrfsfcf{forecast_hour:02d}.grib2",
        "lev_entire_atmosphere": "on",
        "var_REFC": "on",
        "subregion": "",
        "leftlon": f"{longitude - lon_padding:.3f}",
        "rightlon": f"{longitude + lon_padding:.3f}",
        "toplat": f"{latitude + lat_padding:.3f}",
        "bottomlat": f"{latitude - lat_padding:.3f}",
        "dir": f"/hrrr.{cycle:%Y%m%d}/conus",
    }

    url = (
        "https://nomads.ncep.noaa.gov/cgi-bin/filter_hrrr_2d.pl?"
        + urllib.parse.urlencode(params)
    )

    request = urllib.request.Request(
        url,
        headers={"User-Agent": "MorningTVUI/1.0 local-dashboard"},
    )

    with urllib.request.urlopen(
        request,
        timeout=75,
        context=SSL_CONTEXT,
    ) as response:
        payload = response.read()

    if len(payload) < 1000:
        raise RuntimeError("NOAA returned an incomplete HRRR radar file.")

    output.write_bytes(payload)
    return output, valid_time


def _render_reflectivity_frame(grib_path, latitude, longitude, valid_time):
    dataset = xr.open_dataset(
        grib_path,
        engine="cfgrib",
        backend_kwargs={
            "filter_by_keys": {"shortName": "refc"},
            "indexpath": "",
        },
    )

    try:
        data_vars = list(dataset.data_vars)
        if not data_vars:
            raise RuntimeError("HRRR radar file had no reflectivity data.")

        reflectivity = dataset[data_vars[0]].values
        latitudes = dataset["latitude"].values
        longitudes = dataset["longitude"].values

        figure, axis = plt.subplots(figsize=(6.8, 6.0), dpi=130)
        figure.patch.set_facecolor("#edf2f2")
        axis.set_facecolor("#d8e7ea")

        mesh = axis.pcolormesh(
            longitudes,
            latitudes,
            reflectivity,
            shading="auto",
            cmap="turbo",
            vmin=0,
            vmax=65,
        )

        axis.scatter(
            [longitude],
            [latitude],
            s=78,
            marker="*",
            c="#121212",
            edgecolors="#fff8e8",
            linewidths=0.9,
            zorder=5,
        )

        axis.set_xlim(longitude - 0.72, longitude + 0.72)
        axis.set_ylim(latitude - 0.52, latitude + 0.52)
        axis.set_xlabel("Longitude", fontsize=8)
        axis.set_ylabel("Latitude", fontsize=8)
        axis.grid(alpha=0.22, linewidth=0.5)

        local_time = valid_time.astimezone().strftime("%-I:%M %p")
        axis.set_title(
            f"HRRR Forecast Reflectivity — {local_time}",
            fontsize=10,
            fontweight="bold",
        )

        colorbar = figure.colorbar(mesh, ax=axis, shrink=0.84, pad=0.02)
        colorbar.set_label("Reflectivity (dBZ)", fontsize=8)
        colorbar.ax.tick_params(labelsize=7)

        buffer = io.BytesIO()
        figure.savefig(
            buffer,
            format="png",
            bbox_inches="tight",
            facecolor=figure.get_facecolor(),
        )
        plt.close(figure)
        return buffer.getvalue()

    finally:
        dataset.close()


def fetch_forecast_radar_frames(latitude, longitude, selected_start_utc):
    """
    Return two local HRRR reflectivity renderings:
    selected forecast hour and the following forecast hour.
    """
    frames = []

    for offset in (0, 1):
        requested_time = selected_start_utc + timedelta(hours=offset)
        grib_path, valid_time = _download_reflectivity_grib(
            latitude=latitude,
            longitude=longitude,
            target_utc=requested_time,
        )

        image_bytes = _render_reflectivity_frame(
            grib_path=grib_path,
            latitude=latitude,
            longitude=longitude,
            valid_time=valid_time,
        )

        frames.append(
            {
                "image_bytes": image_bytes,
                "valid_time": valid_time,
            }
        )

    return frames
