import hashlib
import io
import json
import math
import os
import ssl
import urllib.error
import urllib.parse
import urllib.request
from concurrent.futures import ThreadPoolExecutor
from datetime import datetime, timedelta, timezone
from pathlib import Path

import certifi
from PIL import Image


SSL_CONTEXT = ssl.create_default_context(cafile=certifi.where())

CACHE_DIR = Path.home() / ".cache" / "MorningTVUI" / "weathercom_radar"
CACHE_DIR.mkdir(parents=True, exist_ok=True)

WEATHERCOM_KEY_FILE = (
    Path.home() / ".config" / "MorningTVUI" / "weathercom_tile_key.txt"
)
MAPBOX_KEY_FILE = (
    Path.home() / ".config" / "MorningTVUI" / "mapbox_key.txt"
)

WEATHERCOM_TILE_ENDPOINT = "https://api.weather.com/v3/TileServer/tile"
MAPBOX_TILE_ENDPOINT = (
    "https://api.mapbox.com/styles/v1/mapbox/streets-v12/tiles/256/{z}/{x}/{y}"
)

OBSERVED_PRODUCT = "twcRadarMosaic"
FORECAST_PRODUCT = "radarFcstV2"

ZOOM = 11
MIN_ZOOM = 6
MAX_ZOOM = 13
TILE_SIZE = 256

# Visible output remains 4-by-3 tiles, matching the radar panel.
# We fetch a slightly larger real tile area and crop it around the precise
# saved-location coordinate, so the hidden location marker is dead-center.
VISIBLE_TILE_COLUMNS = 4
VISIBLE_TILE_ROWS = 3
SOURCE_TILE_COLUMNS = 5
SOURCE_TILE_ROWS = 4

OBSERVED_FRAME_SPACING_MINUTES = 5
PREDICTED_FRAME_SPACING_MINUTES = 15
LOOP_DURATION_MINUTES = 90
RADAR_CACHE_SECONDS = 300
BASEMAP_CACHE_SECONDS = 60 * 60 * 24 * 30
REQUEST_TIMEOUT_SECONDS = 20

FORECAST_RUN_SEARCH_MINUTES = 240
FORECAST_RUN_STEP_MINUTES = 5


def _read_key(path, environment_name):
    key = os.environ.get(environment_name, "").strip()

    if not key and path.exists():
        key = path.read_text(encoding="utf-8").strip()

    if not key:
        raise RuntimeError(
            f"Missing key file: {path}"
        )

    return key


def _read_weathercom_key():
    return _read_key(
        WEATHERCOM_KEY_FILE,
        "WEATHERCOM_TILE_API_KEY",
    )


def _read_mapbox_key():
    return _read_key(
        MAPBOX_KEY_FILE,
        "MAPBOX_ACCESS_TOKEN",
    )


def _floor_to_five_minutes(value):
    value = value.astimezone(timezone.utc)

    return value.replace(
        minute=(value.minute // 5) * 5,
        second=0,
        microsecond=0,
    )


def _tile_coordinates(latitude, longitude, zoom):
    latitude = max(-85.05112878, min(85.05112878, float(latitude)))
    longitude = float(longitude)

    world_size = 2 ** zoom
    x = (longitude + 180.0) / 360.0 * world_size

    latitude_radians = math.radians(latitude)
    y = (
        (
            1.0
            - math.asinh(math.tan(latitude_radians)) / math.pi
        )
        / 2.0
        * world_size
    )

    return x, y


def _load_cached_bytes(path, max_age_seconds):
    try:
        if not path.exists():
            return None

        age = datetime.now(timezone.utc).timestamp() - path.stat().st_mtime

        if age > max_age_seconds:
            return None

        payload = path.read_bytes()

        return payload if len(payload) > 80 else None

    except OSError:
        return None


def _fetch_weathercom_tile(
    product,
    tile_timestamp,
    forecast_timestamp,
    tile_x,
    tile_y,
    zoom,
    api_key,
    quiet=False,
):
    max_tile = (2 ** zoom) - 1
    tile_x %= (2 ** zoom)

    if tile_y < 0 or tile_y > max_tile:
        return None

    params = {
        "product": product,
        "ts": str(int(tile_timestamp)),
        "xyz": f"{tile_x}:{tile_y}:{zoom}",
        "apiKey": api_key,
    }

    if forecast_timestamp is not None:
        params["fts"] = str(int(forecast_timestamp))

    url = WEATHERCOM_TILE_ENDPOINT + "?" + urllib.parse.urlencode(params)

    request = urllib.request.Request(
        url,
        headers={
            "User-Agent": "MorningTVUI/1.0",
            "Accept": "image/webp,image/png,image/*,*/*;q=0.8",
            "Referer": "https://weather.com/",
        },
    )

    try:
        with urllib.request.urlopen(
            request,
            timeout=REQUEST_TIMEOUT_SECONDS,
            context=SSL_CONTEXT,
        ) as response:
            payload = response.read()

        if len(payload) < 80:
            return None

        return Image.open(io.BytesIO(payload)).convert("RGBA").copy()

    except urllib.error.HTTPError as error:
        if not quiet:
            print(
                "Weather.com HTTP error:",
                error.code,
                product,
                "ts=",
                tile_timestamp,
                "fts=",
                forecast_timestamp,
            )
        return None

    except Exception as error:
        if not quiet:
            print(
                "Weather.com tile error:",
                type(error).__name__,
                str(error),
            )
        return None


def _fetch_mapbox_tile(tile_x, tile_y, zoom, api_key):
    max_tile = (2 ** zoom) - 1
    tile_x %= (2 ** zoom)

    if tile_y < 0 or tile_y > max_tile:
        return None

    cache_path = CACHE_DIR / (
        f"basemap_streets_v12_z{zoom}_{tile_x}_{tile_y}.png"
    )

    cached = _load_cached_bytes(
        cache_path,
        BASEMAP_CACHE_SECONDS,
    )

    if cached:
        try:
            return Image.open(io.BytesIO(cached)).convert("RGBA").copy()
        except Exception:
            pass

    url = MAPBOX_TILE_ENDPOINT.format(
        z=zoom,
        x=tile_x,
        y=tile_y,
    )

    url += "?" + urllib.parse.urlencode(
        {"access_token": api_key}
    )

    request = urllib.request.Request(
        url,
        headers={
            "User-Agent": "MorningTVUI/1.0",
            "Accept": "image/png,image/*,*/*;q=0.8",
        },
    )

    try:
        with urllib.request.urlopen(
            request,
            timeout=REQUEST_TIMEOUT_SECONDS,
            context=SSL_CONTEXT,
        ) as response:
            payload = response.read()

        if len(payload) < 100:
            return None

        cache_path.write_bytes(payload)

        return Image.open(io.BytesIO(payload)).convert("RGBA").copy()

    except Exception as error:
        print(
            "Mapbox tile error:",
            type(error).__name__,
            str(error),
        )
        return None


def _map_geometry(latitude, longitude, zoom=ZOOM):
    center_x_float, center_y_float = _tile_coordinates(
        latitude,
        longitude,
        zoom,
    )

    center_x = int(math.floor(center_x_float))
    center_y = int(math.floor(center_y_float))

    # Fetch enough surrounding tiles to crop a 4x3 viewport whose exact
    # center is the saved location, including its fractional tile position.
    start_x = int(math.floor(center_x_float)) - 2
    start_y = int(math.floor(center_y_float)) - 2

    source_width = SOURCE_TILE_COLUMNS * TILE_SIZE
    source_height = SOURCE_TILE_ROWS * TILE_SIZE
    output_width = VISIBLE_TILE_COLUMNS * TILE_SIZE
    output_height = VISIBLE_TILE_ROWS * TILE_SIZE

    center_pixel_x = (center_x_float - start_x) * TILE_SIZE
    center_pixel_y = (center_y_float - start_y) * TILE_SIZE

    crop_left = int(round(center_pixel_x - (output_width / 2)))
    crop_top = int(round(center_pixel_y - (output_height / 2)))

    crop_left = max(0, min(crop_left, source_width - output_width))
    crop_top = max(0, min(crop_top, source_height - output_height))

    return {
        "center_x_float": center_x_float,
        "center_y_float": center_y_float,
        "start_x": start_x,
        "start_y": start_y,
        "tile_columns": SOURCE_TILE_COLUMNS,
        "tile_rows": SOURCE_TILE_ROWS,
        "image_width": source_width,
        "image_height": source_height,
        "crop_box": (
            crop_left,
            crop_top,
            crop_left + output_width,
            crop_top + output_height,
        ),
    }


def _load_basemap_canvas(
    latitude,
    longitude,
    mapbox_key,
    zoom=ZOOM,
):
    geometry = _map_geometry(latitude, longitude, zoom)

    cache_name = (
        f"basemap_canvas_streets_v12_center_source5x4_z{zoom}_"
        f"{geometry['start_x']}_{geometry['start_y']}.png"
    )

    cache_path = CACHE_DIR / cache_name

    cached = _load_cached_bytes(
        cache_path,
        BASEMAP_CACHE_SECONDS,
    )

    if cached:
        try:
            return Image.open(io.BytesIO(cached)).convert("RGBA").copy()
        except Exception:
            pass

    canvas = Image.new(
        "RGBA",
        (geometry["image_width"], geometry["image_height"]),
        (223, 230, 233, 255),
    )

    jobs = []

    with ThreadPoolExecutor(max_workers=7) as executor:
        for row in range(geometry["tile_rows"]):
            for column in range(geometry["tile_columns"]):
                tile_x = geometry["start_x"] + column
                tile_y = geometry["start_y"] + row

                jobs.append(
                    (
                        executor.submit(
                            _fetch_mapbox_tile,
                            tile_x,
                            tile_y,
                            zoom,
                            mapbox_key,
                        ),
                        row,
                        column,
                    )
                )

        loaded_tiles = 0

        for future, row, column in jobs:
            tile = future.result()

            if tile is None:
                continue

            canvas.alpha_composite(
                tile,
                dest=(column * TILE_SIZE, row * TILE_SIZE),
            )

            loaded_tiles += 1

    if loaded_tiles == 0:
        raise RuntimeError(
            "Mapbox did not return usable roads-and-labels map tiles."
        )

    output = io.BytesIO()
    canvas.save(output, format="PNG", optimize=True)
    cache_path.write_bytes(output.getvalue())

    return canvas


def _render_frame(
    latitude,
    longitude,
    product,
    tile_timestamp,
    forecast_timestamp,
    weathercom_key,
    mapbox_key,
    location_label="",
    zoom=ZOOM,
):
    geometry = _map_geometry(latitude, longitude, zoom)

    canvas = _load_basemap_canvas(
        latitude,
        longitude,
        mapbox_key,
        zoom=zoom,
    )

    jobs = []

    with ThreadPoolExecutor(max_workers=7) as executor:
        for row in range(geometry["tile_rows"]):
            for column in range(geometry["tile_columns"]):
                jobs.append(
                    (
                        executor.submit(
                            _fetch_weathercom_tile,
                            product,
                            tile_timestamp,
                            forecast_timestamp,
                            geometry["start_x"] + column,
                            geometry["start_y"] + row,
                            zoom,
                            weathercom_key,
                            True,
                        ),
                        row,
                        column,
                    )
                )

        loaded_tiles = 0

        for future, row, column in jobs:
            tile = future.result()

            if tile is None:
                continue

            canvas.alpha_composite(
                tile,
                dest=(column * TILE_SIZE, row * TILE_SIZE),
            )

            loaded_tiles += 1

    if loaded_tiles == 0:
        return None

    # Crop the larger real tile canvas so the saved location is exactly
    # centered in the visible 4x3 radar/map view.
    canvas = canvas.crop(geometry["crop_box"])

    buffer = io.BytesIO()

    canvas.convert("RGB").save(
        buffer,
        format="JPEG",
        quality=91,
        optimize=True,
    )

    return buffer.getvalue()


def _forecast_probe_tile(latitude, longitude, zoom=ZOOM):
    center_x, center_y = _tile_coordinates(
        latitude,
        longitude,
        zoom,
    )

    return int(math.floor(center_x)), int(math.floor(center_y))


def _discover_forecast_run(
    latitude,
    longitude,
    selected_start_utc,
    weathercom_key,
    zoom=ZOOM,
):
    probe_x, probe_y = _forecast_probe_tile(
        latitude,
        longitude,
        zoom,
    )

    selected_start_utc = _floor_to_five_minutes(
        selected_start_utc
    )

    now_utc = _floor_to_five_minutes(
        datetime.now(timezone.utc)
    )

    test_offsets = (0, 15, 30)

    for minutes_back in range(
        0,
        FORECAST_RUN_SEARCH_MINUTES + 1,
        FORECAST_RUN_STEP_MINUTES,
    ):
        base_time = now_utc - timedelta(minutes=minutes_back)
        successes = 0

        for minutes_forward in test_offsets:
            target_time = selected_start_utc + timedelta(
                minutes=minutes_forward
            )

            image = _fetch_weathercom_tile(
                FORECAST_PRODUCT,
                int(base_time.timestamp()),
                int(target_time.timestamp()),
                probe_x,
                probe_y,
                zoom,
                weathercom_key,
                True,
            )

            if image is not None:
                successes += 1

        if successes >= 2:
            return base_time

    raise RuntimeError(
        "Weather.com did not expose a forecast run "
        "for the selected hour."
    )


def _cache_key(
    latitude,
    longitude,
    selected_start,
    selected_end,
    zoom=ZOOM,
):
    return (
        f"{latitude:.3f}_{longitude:.3f}_radar_cadence_v8_centered4x3_"
        f"z{int(zoom)}_start{int(selected_start.timestamp())}_"
        f"end{int(selected_end.timestamp())}"
    )


def _load_cached_loop(cache_key):
    manifest_path = CACHE_DIR / f"{cache_key}.json"

    if not manifest_path.exists():
        return None

    try:
        manifest = json.loads(
            manifest_path.read_text(encoding="utf-8")
        )

        fetched_at = float(manifest.get("fetched_at", 0))

        if (
            datetime.now(timezone.utc).timestamp() - fetched_at
            > RADAR_CACHE_SECONDS
        ):
            return None

        frames = []

        for item in manifest.get("frames", []):
            image_path = CACHE_DIR / item["file_name"]

            if not image_path.exists():
                return None

            image_bytes = image_path.read_bytes()

            if len(image_bytes) < 100:
                return None

            frames.append(
                {
                    "image_bytes": image_bytes,
                    "valid_time": datetime.fromtimestamp(
                        int(item["valid_timestamp"]),
                        tz=timezone.utc,
                    ),
                    "radar_type": item["radar_type"],
                    "base_time": datetime.fromtimestamp(
                        int(item["base_timestamp"]),
                        tz=timezone.utc,
                    ),
                }
            )

        return frames if len(frames) >= 4 else None

    except Exception:
        return None


def _save_cached_loop(cache_key, frames):
    manifest_frames = []

    for index, frame in enumerate(frames):
        file_name = f"{cache_key}_{index:02d}.jpg"

        (CACHE_DIR / file_name).write_bytes(
            frame["image_bytes"]
        )

        manifest_frames.append(
            {
                "file_name": file_name,
                "valid_timestamp": int(
                    frame["valid_time"].timestamp()
                ),
                "base_timestamp": int(
                    frame["base_time"].timestamp()
                ),
                "radar_type": frame["radar_type"],
            }
        )

    (CACHE_DIR / f"{cache_key}.json").write_text(
        json.dumps(
            {
                "fetched_at": datetime.now(
                    timezone.utc
                ).timestamp(),
                "frames": manifest_frames,
            },
            indent=2,
        ),
        encoding="utf-8",
    )


def _prune_cache():
    cutoff = datetime.now(timezone.utc).timestamp() - (
        60 * 60 * 24 * 35
    )

    try:
        for path in CACHE_DIR.iterdir():
            if path.is_file() and path.stat().st_mtime < cutoff:
                path.unlink(missing_ok=True)
    except OSError:
        pass


def _ceil_to_next_quarter_hour(value):
    value = value.astimezone(timezone.utc).replace(
        second=0,
        microsecond=0,
    )

    remainder = value.minute % PREDICTED_FRAME_SPACING_MINUTES

    if remainder == 0:
        return value

    return value + timedelta(
        minutes=PREDICTED_FRAME_SPACING_MINUTES - remainder
    )


def _build_observed_times(selected_start_utc, selected_end_utc, now_utc):
    latest_observed = min(selected_end_utc, now_utc)

    if selected_start_utc > latest_observed:
        return []

    times = []
    value = selected_start_utc

    while value <= latest_observed:
        times.append(value)
        value += timedelta(minutes=OBSERVED_FRAME_SPACING_MINUTES)

    return times


def _build_predicted_times(selected_start_utc, selected_end_utc, now_utc):
    first_future_time = max(
        selected_start_utc,
        now_utc + timedelta(minutes=1),
    )

    value = _ceil_to_next_quarter_hour(first_future_time)
    times = []

    while value <= selected_end_utc:
        times.append(value)
        value += timedelta(minutes=PREDICTED_FRAME_SPACING_MINUTES)

    return times


def _render_observed_frame(
    latitude,
    longitude,
    valid_time,
    weathercom_key,
    mapbox_key,
    location_label="",
    zoom=ZOOM,
):
    image_bytes = _render_frame(
        latitude=latitude,
        longitude=longitude,
        product=OBSERVED_PRODUCT,
        tile_timestamp=int(valid_time.timestamp()),
        forecast_timestamp=None,
        weathercom_key=weathercom_key,
        mapbox_key=mapbox_key,
        location_label=location_label,
        zoom=zoom,
    )

    if not image_bytes:
        return None

    return {
        "image_bytes": image_bytes,
        "valid_time": valid_time,
        "radar_type": "OBSERVED RADAR",
        "base_time": valid_time,
    }


def _render_predicted_frame(
    latitude,
    longitude,
    valid_time,
    forecast_base_time,
    weathercom_key,
    mapbox_key,
    location_label="",
    zoom=ZOOM,
):
    image_bytes = _render_frame(
        latitude=latitude,
        longitude=longitude,
        product=FORECAST_PRODUCT,
        tile_timestamp=int(forecast_base_time.timestamp()),
        forecast_timestamp=int(valid_time.timestamp()),
        weathercom_key=weathercom_key,
        mapbox_key=mapbox_key,
        location_label=location_label,
        zoom=zoom,
    )

    if not image_bytes:
        return None

    return {
        "image_bytes": image_bytes,
        "valid_time": valid_time,
        "radar_type": "PREDICTED RADAR",
        "base_time": forecast_base_time,
    }


def _normalize_radar_window(selected_start_utc, selected_end_utc=None):
    selected_start_utc = _floor_to_five_minutes(
        selected_start_utc
    )

    if selected_end_utc is None:
        selected_end_utc = selected_start_utc + timedelta(
            minutes=LOOP_DURATION_MINUTES
        )
    else:
        selected_end_utc = _floor_to_five_minutes(
            selected_end_utc
        )

    if selected_end_utc < selected_start_utc:
        raise ValueError(
            "Radar end time must be after the radar start time."
        )

    return selected_start_utc, selected_end_utc


def load_cached_weathercom_radar_frames(
    latitude,
    longitude,
    selected_start_utc,
    selected_end_utc=None,
    zoom=ZOOM,
):
    selected_start_utc, selected_end_utc = _normalize_radar_window(
        selected_start_utc,
        selected_end_utc,
    )

    return _load_cached_loop(
        _cache_key(
            latitude,
            longitude,
            selected_start_utc,
            selected_end_utc,
            zoom=zoom,
        )
    )


def fetch_weathercom_radar_frames(
    latitude,
    longitude,
    selected_start_utc,
    selected_end_utc=None,
    location_label="",
    zoom=ZOOM,
):
    zoom = max(MIN_ZOOM, min(MAX_ZOOM, int(zoom)))

    weathercom_key = _read_weathercom_key()
    mapbox_key = _read_mapbox_key()

    selected_start_utc = _floor_to_five_minutes(
        selected_start_utc
    )

    if selected_end_utc is None:
        selected_end_utc = selected_start_utc + timedelta(
            minutes=LOOP_DURATION_MINUTES
        )
    else:
        selected_end_utc = _floor_to_five_minutes(
            selected_end_utc
        )

    if selected_end_utc < selected_start_utc:
        raise ValueError(
            "Radar end time must be after the radar start time."
        )

    now_utc = _floor_to_five_minutes(
        datetime.now(timezone.utc)
    )

    cache_key = _cache_key(
        latitude,
        longitude,
        selected_start_utc,
        selected_end_utc,
        zoom=zoom,
    )

    cached = _load_cached_loop(cache_key)

    if cached:
        print(
            "Radar cache hit:",
            selected_start_utc.isoformat(),
            f"({len(cached)} actual frames)",
        )
        return cached

    observed_times = _build_observed_times(
        selected_start_utc,
        selected_end_utc,
        now_utc,
    )

    predicted_times = _build_predicted_times(
        selected_start_utc,
        selected_end_utc,
        now_utc,
    )

    forecast_base_time = None

    if predicted_times:
        forecast_base_time = _discover_forecast_run(
            latitude=latitude,
            longitude=longitude,
            selected_start_utc=predicted_times[0],
            weathercom_key=weathercom_key,
            zoom=zoom,
        )

    print(
        "Radar loop request:",
        selected_start_utc.isoformat(),
        "through",
        selected_end_utc.isoformat(),
        f"observed={len(observed_times)} at 5 minutes,",
        f"predicted={len(predicted_times)} at 15 minutes",
    )

    frames = []

    for valid_time in observed_times:
        frame = _render_observed_frame(
            latitude=latitude,
            longitude=longitude,
            valid_time=valid_time,
            weathercom_key=weathercom_key,
            mapbox_key=mapbox_key,
            location_label=location_label,
            zoom=zoom,
        )

        if frame:
            frames.append(frame)
            print(
                "Radar frame:",
                valid_time.isoformat(),
                "OBSERVED RADAR",
            )
        else:
            print(
                "Observed frame unavailable:",
                valid_time.isoformat(),
            )

    for valid_time in predicted_times:
        frame = _render_predicted_frame(
            latitude=latitude,
            longitude=longitude,
            valid_time=valid_time,
            forecast_base_time=forecast_base_time,
            weathercom_key=weathercom_key,
            mapbox_key=mapbox_key,
            location_label=location_label,
            zoom=zoom,
        )

        if frame:
            frames.append(frame)
            print(
                "Radar frame:",
                valid_time.isoformat(),
                "PREDICTED RADAR",
            )
        else:
            print(
                "Predicted frame unavailable:",
                valid_time.isoformat(),
            )

    frames.sort(key=lambda item: item["valid_time"])

    if len(frames) < 4:
        raise RuntimeError(
            "Weather.com returned fewer than four usable "
            "frames for this 90-minute radar window."
        )

    _save_cached_loop(cache_key, frames)
    _prune_cache()

    observed_count = sum(
        1
        for frame in frames
        if frame["radar_type"] == "OBSERVED RADAR"
    )

    predicted_count = len(frames) - observed_count

    print(
        "Radar loop complete:",
        f"{len(frames)} actual frames",
        f"observed={observed_count}",
        f"predicted={predicted_count}",
    )

    return frames


def preload_weathercom_radar_loops(
    latitude,
    longitude,
    selected_windows,
    location_label="",
):
    ready = 0
    failed = 0
    unique_windows = []

    for item in selected_windows or []:
        if not isinstance(item, (tuple, list)) or not item:
            continue

        selected_start_utc = item[0]
        selected_end_utc = item[1] if len(item) > 1 else None

        if not isinstance(selected_start_utc, datetime):
            continue

        try:
            selected_start_utc, selected_end_utc = _normalize_radar_window(
                selected_start_utc,
                selected_end_utc,
            )
        except Exception:
            continue

        window = (selected_start_utc, selected_end_utc)

        if window not in unique_windows:
            unique_windows.append(window)

    for selected_start_utc, selected_end_utc in unique_windows:
        try:
            frames = fetch_weathercom_radar_frames(
                latitude=latitude,
                longitude=longitude,
                selected_start_utc=selected_start_utc,
                selected_end_utc=selected_end_utc,
                location_label=location_label,
            )

            ready += 1

            print(
                "Radar preload ready:",
                selected_start_utc.isoformat(),
                "through",
                selected_end_utc.isoformat(),
                f"({len(frames)} actual frames)",
            )

        except Exception as error:
            failed += 1

            print(
                "Radar preload failed:",
                selected_start_utc.isoformat(),
                error,
            )

    return {
        "ready": ready,
        "failed": failed,
        "requested": len(unique_windows),
    }
